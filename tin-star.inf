      return room37;
  ],
  s_to room35,
  e_to "You're alone and on foot. It would be better to wait for the bandits here, as they're sure to return before long.",
  in_to room37,
  before
  [;
    Hint:
      if (room37 hasnt visited)
        "Hide until the bandits return.";
  ],
has light;

