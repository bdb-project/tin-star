!========================================
Object room12 "Desert"
with
  name 'desert',
  description
  [;
    print_ret (string)DESERT_DESCRIPTION;
  ],
  n_to room13,
  s_to room12,
  e_to room08,
  w_to room13,
  cheap_scenery
    1 'sand' "The glaring sun turns it into a sea of gold, but there's no richness here - only death."
    1 'sun' "Hot. Relentless.",
has horsey light;

!========================================
! Room 13: Desert
!========================================
Object room13 "Desert"
with
  name 'desert',
  description
  [;
    print_ret (string)DESERT_DESCRIPTION;
  ],
  n_to room07,
  s_to room12,
  e_to room08,
  w_to room12,
  cheap_scenery
    1 'sand' "The glaring sun turns it into a sea of gold, but there's no richness here - only death."
    1 'sun' "Hot. Relentless.",
has horsey light;

!----------------------------------------
! Carcass of a horse
!----------------------------------------
Object item10 "carcass of a horse" room13
with
  article "the",
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'carcass' or 'of' or 'dead' or 'horse')
    {
      i++;
      if (nw == 'horse' && TestScope(horse))
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description 
  [;
    print "It's a dead horse, possibly left here by the owner while trying to cross this deadly place. It's been stripped of its harness, bridle and saddle. ";
    if (saddle_bag hasnt moved)
      print "Only a battered saddle bag has been left beside the carcass.";
    "";
  ],
has animate neuter;

!----------------------------------------
! Saddle bag
!----------------------------------------
Object saddle_bag "saddle bag" room13
with
  name 'saddle' 'bag',
  description
  [;
    print "It's an old and battered saddle bag. ";
    <<Search self>>;
  ],
  before
  [;
    Receive:
      if (noun ~= pemmican && noun ~= canteen)
        print_ret (The)noun, " won't fit in the saddle bag.";
  ],
has container openable;

!----------------------------------------
! Pemmican
!----------------------------------------
Object pemmican "pemmican" saddle_bag
with
  article "some",
  name 'pemmican',
  description "A pressed cake of pounded dried meat mixed to a paste with melted fat and other ingredients. It's a Native American food.",
  before [;
    Eat:
      if (p_has_drunk == false)
        "Your mouth is too dry to eat. You need to drink some water first.";
      else {
        p_has_eaten = true;
        give player general;
        move self to limbo;
        "You feel your strength coming back and you can now mount your horse, provided he has drunk as well.";
      }
  ],
has edible;

!----------------------------------------
! Canteen
!----------------------------------------
Object canteen "canteen" saddle_bag
with
  article "a",
  name 'canteen',
  description
  [;
    print "It's a small metallic bottle, used as a small reserve of water. It's currently ";
    if (self hasnt general)
      "empty.";
    else
      "full of water.";
  ],
  invent
  [;
    if (inventory_stage == 2)
      if (self hasnt general)
        print " (empty)";
      else
        print " (full of water)";
  ],
  before
  [;
    Drink:
      if (p_has_drunk == false)
      {
        p_has_drunk = true;
        room03.turns_active = 0; 
        StopDaemon(room03);
        print "You drink from the canteen. After what you've been through in the desert, you feel so refreshed.";
        if ((player hasnt general) && (p_has_eaten == true))
        {
          give player general;
          print " You feel your strength coming back.";
        }
      "";
      }
      else "You drink a sip from the water out of the canteen.";
    Empty:
      if (self hasnt general)
        "There's nothing in it.";
      give self ~general;
      "You empty the canteen and the water dissipates. A silly move to do in your current predicament.";
    Fill:
      if (self has general)
        "It's already full.";
      if (second == nothing && water in location)
      {
        print "(with water)^";
        <<FillWith self water>>;
      }
      if (second == nothing)
        "You'll need to tell me what to fill it with.";
      if (second == basin && second in location)
      {
        give self general;
        "You fill the canteen with water from the basin.";
      }
      "There's nothing here that you can use to fill the canteen.";
    FillWith:
      if (self has general)
        "It's already full.";
      if (second == water && second in location)
      {
        give self general;
        "You fill the canteen with water from the basin.";
      }
      "There's nothing here that you can use to fill the canteen.";
    Receive:
      "Only water can be put in the canteen.";
  ],
has container openable;

!========================================
! Room 14: Large Gash in Tunnels
!========================================
Object room14 "Large Gash in Tunnels"
with
  name 'large' 'gash' 'in' 'tunnels',
  description "The bright light of day breaks violently through the large gash produced by the dynamite, suffocated to the north and east by the dark mouth of two secondary tunnels. To the south, beyond the entrance, a large plateau extends under the summer sun.",
  n_to room09,!Conditional
  s_to room20,
has light;

!========================================
! Room 15: North Side of Gorge
!========================================
Object room15 "North Side of Gorge"
with
  name 'north' 'side' 'of' 'deep' 'gorge',
  description "When you reach the end of the tunnel, you find yourself in the open, on the edge of a deep precipice. It is the north side of a deep gorge, and on the other side you can see a group of rocks behind which smoke seems to emerge. Behind you is the entrance to the mining tunnel from which you came. A cluster of trees is adjacent to the ravine.",
  n_to room37,
  in_to room37,!Conditional
  !CROSS takes you to room21
  s_to "You cannot go south since the bridge has been destroyed.",
has light;

!----------------------------------------
! Long bridge
!----------------------------------------
Object item30 "long bridge that hangs along the side of the chasm" room15
with
  name 'long' 'bridge',
  description "The bridge was probably cut down by the band of outlaws, and it now hangs along this side of the chasm. It is impossible to use it, so you must find another way to get to the south side.",
has static;

!----------------------------------------
! Cluster of trees
!----------------------------------------
Object trees "cluster of trees next to the edge of chasm" room15
with
  name 'cluster' 'tree' 'trees',
  description "Some very high trees grow close to the edge of the chasm. Maybe cutting one down could help you to cross it.",
  before [;
    Cut:
      if (item29 in player)
        if (item31 notin nothing)
          "You already cut a tree. There is no need to eradicate the entire forest.";
        move item31 to room15;
        room15.s_to = room21;
        "With considerable difficulty you finally manage to knock down one of the tallest trees, which falls towards the other side of the ravine, forming an excellent makeshift bridge.";
  ],
has scenery;

!----------------------------------------
! Long log
!----------------------------------------
Object item31 "long log that allows you to cross the chasm" !room15
with
  name 'long' 'log',
  description "A makeshift bridge formed by a tree you just choppped down.",
has static;

!========================================
! Room 16: Inside Old Building
!========================================
Object room16 "Inside Old Building"
with
  name 'interior' 'of' 'old' 'building',
  description "The interior of the old building shows clear signs of abandonment, but, in one corner, a small, almost extinguished fire lets out a thin wisp of smoke that disappears, high up, between the rotten beams of the ceiling. A broken window allows you to look out to monitor the situation. You can go out the building heading south.",
  cheap_scenery
			11 'rotten' 'beams' "There is nothing special about the beans."
      1 'smoke' "Almost non-existent, yet present."
      2 'extinguished' 'fire' "There is nothing special about it, except for the fact that it indicates people somewhat live here, and might be back soon.",
  s_to room22,
  out_to room22,
  before [;
    Shoot:  
      if (rifle notin player)
        "You have nothing you can use to shoot.";
      if (item32 notin nothing)
      {
        !if (second == nothing)
         ! "Shooting random objects will just get you killed, here.";
        if (noun == window)
          {
            print "(with the rifle)^";
            <<Shoot item32 rifle>>;
          }
        deadflag = 2;
        "Hiding yourself with the window, you fire on the bandits, and with unerring aim you pick them off one by one before they have time to fire on you.^^Congratulations, sheriff!^^Once again the law triumphs, thanks to a man of valor who defends it at the cost of his own life. The people of Tucson will always remember your action.";
      }
      else "Save you bullets for later. There is nothing to shoot at.";
  ],
  each_turn [; StartDaemon(self); ],
	  turns_active,
	  daemon [;
			switch (++(self.turns_active)) {
        3: move item32 to room22;
           "^Suddenly, you hear people laughing and screaming, almost covering the rumble of approaching horses.";
        5: "^Looking through the window, you can see they are dismounting to water the horses.";
        7: "^Talking in Spanish, they start joking about their carnage. Their laugh is unbearable.";
        9: "^It looks like the bandits are almost ready to leave.";
        10: self.turns_active = 0; 
            StopDaemon(self); 
            deadflag = 1;
            "^At a certain point, the one who seems to be their boss calls everyone to attention. The bandits mount their horses again and off they go, for a new carnage. You missed your only opportunity to kill them, and the law won't be restored. Not this time, at least.";
        }
		],
has light;

!----------------------------------------
! Window
!----------------------------------------
Object window "broken window" room16
with
  name 'broken' 'window',
  before [;
    Examine:
     if (item32 in nothing)
       "Looking through the window you can see the outside is clear of bandits, at the moment.";
    else 
    "It looks like the people you were looking for have finally arrived. Maybe you can try to shoot through the window to take them down.";
  ],
has scenery;

