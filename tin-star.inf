!========================================
! Room 37: Inside Old Building
!========================================
Object room37 "Inside Old Building"
with
  description "The interior of the old building shows clear signs of abandonment. In one corner, there's a small fire that hasn't been properly extinguished. A thin wisp of smoke comes from the fire and disappears through the rotten beams of the ceiling. A broken window allows you to monitor the situation outside. The exit from the building is to the south.",
  s_to room36,
  out_to room36,
  before
  [;
    Go:
      if (selected_direction == s_to or out_to)
      {
        print "Stay here. The bandits ";
        if (bandits notin self)
          "are sure to return and this will make a good place for an ambush.";
        else
          "will see you if you venture onto the street.";
      }
    Hint:
      if (bandits notin self)
        "Be patient. The bandits can't be far away.";
      "The bandits are here! Don't wait too long. Shoot them before they leave.";
    Listen:
      if (bandits in self)
        "You hear the bandits talking in Spanish, but you can't make out what they're saying.";
  ],
  after
  [;
    Go:
      if (self hasnt visited)
        StartDaemon(self);
  ],
  daemon
  [;
    switch (self.time_left++)
    {
      3: "^Suddenly, you hear the rumble of approaching horses.";
      4: move bandits to room37;
        "^Looking through the window, you see the horses arrive outside in a cloud of dust.";
      5: "^The men dismount to water their horses. It's the bandits!";
      6: "^The bandits look like Mexicans. They're talking in Spanish.";
      7: "^The bandits start joking about their carnage. Their laugh is unbearable and makes you feel sick to the stomach.";
      8: "^The bandits haven't spotted you yet. Now is the time to hand out justice...wild west style.";
      9: "^It looks like the bandits are getting ready to leave.";
      10: deadflag = 1;
          "^The bandits are just about to mount their horses when the leader sees you moving about in the shadows through the window of the building. ~Oye, hay un gringo en la casa.~ Before you have a chance to react, the bandits draw their weapons and shoot you down in a barrage of bullets.^^Too bad. You missed your opportunity and won't get another one, now that you're riddled with bullets and lying on the ground in a pool of blood.";
    }
  ],
  time_left 0,
has light;

