has pluralname scenery;

!----------------------------------------
! Window
!----------------------------------------
Object window "window" room37
with
  name 'broken' 'window',
  before
  [;
    Examine:
      print "Looking through the window, you can see that the ";
      if (bandits in nothing)
        "road is clear of people.";
      else
        "bandits you were seeking have finally arrived. You'd better shoot them through the window before they see you.";
  ],
has scenery;

!----------------------------------------
! Bandits
!----------------------------------------
Object bandits "bandits in the street" !room37
with
  article "a group of",
  name 'band' 'group' 'of' 'bandits',
  description "Those are the bandits you were looking for.",
  before
  [;
    Shoot:
      if (second == nothing && rifle in player)
      {
        print "(with the rifle)^";
        second = rifle;
      }
      if (second == nothing)
        "You don't have a firearm.";
      if (second ~= rifle)
        "You can't shoot them with ", (a)second, ".";
      deadflag = 2;
      "Hiding behind the broken window, you fire on the bandits and pick them off one by one. The bandits look around in confusion to see where the gunfire is coming from. By the time they realise the source of the ambush, they're all dead. Justice has been served. No one will mourn for those animals.^^Congratulations, sheriff! Once again, the law triumphs. The people of Tucson who lost family and friends to these scum will always remember your bravery when it came to tracking down these criminals.";
  ],
has animate pluralname;

!========================================
! Limbo
!========================================
Object limbo;

!========================================
! Printing rules
!========================================
[ consultWord word i;
  for (i=0:i<WordLength(word):i++)
    print (char)LowerCase(WordAddress(word)->i);
];

[ DoesntOrDont obj;
  if (obj has pluralname)
    print "don't";
  else
    print "doesn't";
];

[ firstConsultWord word i;
  for (i=0:i<WordLength(word):i++)
    if (i == 0)
      print (char)UpperCase(WordAddress(word)->i);
    else
      print (char)LowerCase(WordAddress(word)->i);
];

!========================================
! Other routines
!========================================
[ LowerCase c; ! for ZSCII matching ISO 8859-1
  switch (c)
  {
    'A' to 'Z': c = c + 32;
    202, 204, 212, 214, 221: c--;
    217, 218: c = c - 2;
    158 to 160, 167, 168, 208 to 210: c = c - 3;
    186 to 190, 196 to 200: c = c - 5 ;
    175 to 180: c = c - 6;
  }
  return c;
];

[ UpperCase c; ! for ZSCII matching ISO 8859-1
  switch (c)
  {
    'a' to 'z': c = c - 32;
    201, 203, 211, 213, 220: c++;
    215, 216: c = c + 2;
    155 to 157, 164, 165, 205 to 207: c = c + 3;
    181 to 185, 191 to 195: c = c + 5 ;
    169 to 174: c = c + 6;
  }
  return c;
];

[ PlayerDescription;
  print "Your name is Kenneth Johnson and you're the sheriff of Tucson. You're on the trail of the bandits that robbed the bank in Tucson. It's a dangerous undertaking, but it's your duty to catch them. You're ";
  if (rope has static)
    "currently tied up with a rope. You'll have to get yourself free if you expect to catch those bandits. If you don't, you'll fry in the desert sun.";
  if (bulk_water hasnt general)
    "dying of thirst. You need to get some water.";
  if (player hasnt general)
    "hungry. You need to get some food into you.";
  else
    "now fully nourished, so you have no excuse for not catching them.";
];

!========================================
! Grammar
!========================================
[ isMakeable;
  if (scope_stage == 1)
    rfalse;!Don't allow multiple objects
  if (scope_stage == 2)
  {
    PlaceInScope(smoke);
    rfalse;
  }
  if (scope_stage == 3)
    "You don't know how to make that.";
];

Extend 'ask'
  * 'about' topic -> AskAbout;

Extend 'blow'
  * 'on'/'onto' noun -> Blow
  * 'out' noun -> Extinguish
  * noun 'out' -> Extinguish;

Extend 'cut' first
  * noun 'with' held -> Cut;

Extend 'dig'
  * -> Dig;

Extend 'drink' replace
  * noun -> Drink
  * noun 'from' noun -> Drink
!  * 'from' held -> DrinkFrom
  * 'from' noun -> DrinkFrom;

Extend 'fill' first
  * noun 'with' noun -> FillWith;

Extend 'get' first
  * noun 'with'/'in' noun -> Take;

Extend only 'kill' replace
  * noun -> Kill
  * noun 'with' held -> Kill;

Extend 'lock' first
  * noun -> Lock;

Extend 'look'
  * 'into' noun -> Search
  * 'out' noun -> Examine
  * 'through' noun -> Examine
  * 'behind'/'under' noun -> LookUnder;

Extend only 'put'
  * 'out' noun -> Extinguish
  * noun 'out' -> Extinguish;

Extend 'read' first
  * noun -> Read;

Extend only 'say' first
  * topic -> Say;

Extend only 'speak' replace
  * -> Talk
  * creature -> Talk
  * noun -> Talk
  * 'to'/'with' creature -> Talk
  * 'to'/'with' noun -> Talk
  * 'to'/'with' creature 'about' topic -> Ask
  * 'to'/'with' noun 'about' topic -> Ask;

Extend 'take' first
  * noun 'with'/'in' noun -> Take;

Extend 'unlock' first
  * noun -> Unlock;

Verb meta 'about' 'info'
  * -> About;

Verb meta 'credits'
  * -> Credits;

Verb 'cross' = 'enter';

Verb 'dance'
  * -> Dance;

Verb 'dismount'
  * -> Exit
  * creature -> Exit;

Verb 'extinguish' 'douse' 'snuff' 'unlight'
  * noun -> Extinguish;

Verb 'fire'
  * held -> Fire
  * held 'at' noun -> Shoot reverse
  * 'at' noun 'with' held -> Shoot;

Verb meta 'help' 'instructions'
  * -> Help;

Verb 'hint' 'clue'
  * -> Hint;

Verb 'inspect' = 'examine';

Verb 'kick' = 'attack';

Verb 'make' 'send'
  * scope=isMakeable -> Make
  * scope=isMakeable 'with' held -> Make;

Verb 'mount' 'ride'
  * -> Mount
  * creature -> Mount;

Verb 'revive'
  * creature -> Revive;

Verb 'shoot'
  * -> Shoot
  * noun -> Shoot
  * noun 'with' held -> Shoot
  * 'at' noun -> Shoot
  * 'at' noun 'with' held -> Shoot
  * held 'at' noun -> Shoot reverse;

Verb 'talk' 'babble' 'chat' 'communicate' 'converse' 'gab' 'gossip'
  * -> Talk
  * creature -> Talk
  * noun -> Talk
  * 'to'/'with' creature -> Talk
  * 'to'/'with' noun -> Talk
  * 'to'/'with' creature 'about' topic -> Ask
  * 'to'/'with' noun 'about' topic -> Ask;

Verb 'untie' 'disconnect' 'detach' 'unfasten'
  * -> Untie
  * noun -> Untie
  * noun 'from' noun -> Untie;

Verb 'use'
  * noun -> Use;

Verb 'xyzzy' 'plover' 'plugh' 'yoho'
  * -> MagicWord;

!========================================
! Actions
!========================================
[ AboutSub;
  print "This game is adapted from a semi-graphic Italian adventure written by Bonaventura Di Bello using The Quill and Illustrator. It was originally published by Edizioni Hobby S.r.l. as 'Kenneth Johnson: Tin Star' on the cover tape of 'Viking', no. 5, May 1987 for the ZX Spectrum and Commodore 64.^^The data was extracted from the C64 version using UnQuill, translated to English and rewritten for a modern audience with the original author's permission. The new version includes many enhancements that weren't in the original. The coding was done using Inform 6 and the PunyInform library.^^";
  <<Credits>>;
];

[ AskAboutSub x count npc;
  objectloop (x in location && x has animate && x ~= player)
  {
    count++;
    npc = x;
  }
  if (count == 0)
    "There's no one here to answer your questions.";
  if (count == 1)
    <<Ask npc noun>>;
  "As there are multiple characters here, you'll have to specify who to ask, e.g. ASK MAN ABOUT DOG.";
];

[ CreditsSub;
  "Original story and map by Gentili Gian Paolo.^Adaptation and programming by Bonaventura Di Bello.^Technical support by Max Di Bello.^English translation and game skeleton by Gianluca Girelli.^Game redesign and coding by Gianluca Girelli and Garry Francis.^Play testing by Charles Moore Jr, Garry Francis, Jade J Aincioa, Piergiorgio D'Errico, R J Kowalski and Robert Eggleston.";
];

[ DanceSub;
  "This is not the time or place for dancing.";
];

[ DrinkSub;
  if (ObjectIsUntouchable(noun))
    return;
  "You can't drink ", (ThatOrThose)noun, ".";;
];

[ DrinkFromSub;
  if (ObjectIsUntouchable(noun))
    return;
  print_ret (string)YOU_CANT_DRINK_FROM, (ThatOrThose)noun, ".";;
];

[ ExtinguishSub;
  if (ObjectIsUntouchable(noun))
    return;
  "You can't extinguish ", (ThatOrThose)noun, ".";
];

[ FillWithSub;
  "You can't fill ", (the)noun, " with ", (ThatOrThose)second, ".";
];

[ FireSub;
  if (noun == nothing)
    "You'll have to tell me what to fire.";
  if (ObjectIsUntouchable(noun))
    return;
  "You'll have to tell me what to fire at.";
];

!Delete GoSub if diagonal directions are used
[ GoSub _prop;
  if (selected_direction == ne_to or nw_to or se_to or sw_to)
    "There are no diagonal directions in this game.";
  _prop = selected_direction;
#Iftrue RUNTIME_ERRORS > RTE_MINIMUM;
  if (_prop == 0)
    return _RunTimeError(ERR_INVALID_DIR_PROP);
#Endif;
  return GoDir(_prop);
];

[ HelpSub;
  "Tell me what to do using simple commands starting with a verb.^^Use LOOK (or L) to refresh the location description. Identify all the objects in the description and EXAMINE (or X) each one. Read responses carefully for hints.^^Use compass directions (N, S, E, W, U and D) to move around. Draw a map as you go.^^Use GET or TAKE to take objects and DROP to drop them again. Use WEAR to wear things like clothing and REMOVE to remove anything that's currently worn. Use INVENTORY (or I) to see what you're carrying and wearing.^^Use AGAIN (or G) to repeat the last command.^^Use UNDO to undo the last command if you make a mistake.^^Use SAVE to save the game and RESTORE to restore it again.^^There are over 100 verbs that you can use, so if something doesn't work, try a different verb or a different way of doing things. Use HINT if you get stuck.^^For full instructions, see the game page at <https://bdb-project.itch.io/tin-star>.";
];

[ HintSub;
  if (desert in location)
    "If you're lost in the desert, try dropping an item in each location to make it unique. You can then map the desert and collect your dropped items later.";
  "Examine everything you find and draw a map.";
];

[ LockSub k;
  if (ObjectIsUntouchable(noun))
    return;
  if (noun hasnt lockable)
  {
    PrintMsg(MSG_LOCK_NOT_A_LOCK, 'lock');
    rtrue;
  }
  if (noun has locked)
  {
    PrintMsg(MSG_LOCK_ALREADY_LOCKED);
    rtrue;
  }
  if (noun has open)
  {
    PrintMsg(MSG_LOCK_CLOSE_FIRST);
    rtrue;
  }
  k = RunRoutines(noun, with_key);
  if (k == nothing)
    "You can't see how to lock ", (ItOrThem)noun, ".";
  if (second == nothing && k ~= nothing && k in player)
  {
    second = k;
    print "(with ", (the)second, ")^";
  }
  if (second == nothing)
    "You don't have the key.";
  if (second ~= k)
  {
    PrintMsg(MSG_LOCK_KEY_DOESNT_FIT);
    rtrue;
  }
  give noun locked;
  run_after_routines_msg = MSG_LOCK_DEFAULT;
  run_after_routines_arg_1 = 'lock';
];

[ ShootSub;
  if (noun == nothing)
    "You point your finger in the air and say, ~Bang!~";
  if (ObjectIsUntouchable(noun))
    return;
  if (second == nothing && rifle in player)
  {
    print "(with the rifle)^";
    second = rifle;
  }
  if (second == nothing)
    print_ret (string)YOU_NEED_FIREARM;
  if (second ~= rifle)
    print_ret (string)YOU_CANT_SHOOT_ANYTHING_WITH, (a)second, ".";
  "You can't just go around shooting things arbitrarily, especially in the Wild West. Choose your target carefully or it might get you killed.";
];

[ KillSub;
  "You need to be more specific. Try a verb like SHOOT.";
];

[ LookUnderSub;
  if (location == thedark)
    "But it's dark.";
  "You find nothing of interest.";
];

[ MakeSub;
  "You don't have the materials required to make ", (ThatOrThose)noun, ".";
];

[ MagicWordSub;
  print "There's a puff of smoke and Yosemite Sam appears out of nowhere. He's waving a pair of six-shooters.^^";
  switch (random(5))
  {
    1: print "~Say yer prayers, ya long-eared, fur-bearin', flat-footed varmint.~";
    2: print "~Start prayin', ya long-eared galoot!~";
    3: print "~I'm gonna fill yer full of lead! So long, sucker!~";
    4: print "~I'll blow yer carcass right out from under yer hat!~";
    5: print "~Ya better say yer prayers, ya flea-bitten varmint. I'm a gonna blow ya to kingdom come!~";
  }
  print "^^He looks around, confused. ";
  switch (random(10))
  {
    1: print "~Great horny toads! Where's that fur-bearin' carpet-bagger?~";
    2: print "~Jumpin' Jehoshaphat. I'll blast that rabbit to smithereens!~";
    3: print "~Ooh, I'd like to lay my hands on that lily-livered varmint.~";
    4: print "~Blast it! Where's that long-eared varmint?~";
    5: print "~Oooooo! I hate that rabbit! I'll blast his head off for this!~";
    6: print "~That ornery fur-bearin' varmint. He'll pay for this!~";
    7: print "~That dirty double-crosser! I'm a-comin' back, and I ain't comin' back to play marbles!~";
    8: print "~Now where's that varmint a-hidin'? I'll blast the fur clean off his flea-bitten hide!~";
    9: print "~That double crossin' rabbit. I'll tear him limb from limb!~";
    10: print "~I'll fix his wagon, the cotton-pickin' varmint!~";
  }
  "^^With that, he fades into the distance.";
];

[ MountSub;
  if (noun == nothing && horse in location)
    noun = horse;
  if (noun == nothing)
    "You need to be more specific.";
  if (ObjectIsUntouchable(noun))
    return;
  <<Enter noun>>;
];

[ ReadSub;
  if (ObjectIsUntouchable(noun, true))
    "I suppose you read tea leaves, too.";
  "There's nothing legible on ", (ThatOrThose)noun, ".";
];

[ SaySub i;
  if (consult_words == 0)
    "You have nothing to say.";
  print "~";
  i = consult_from;
  print (firstConsultWord)i++;
  while (i < consult_from + consult_words)
    print " ", (consultWord)i++;
  print ".~^^";
  wn = consult_from;
  if (consult_words == 1 && NextWord() == 'xyzzy' or 'plover' or 'plugh' or 'yoho')
    <<MagicWord>>;
  if (AfterRoutines())
    return;
  "Nothing happens.";
];

[ TalkSub;
  if (noun == nothing)
    "You start talking to no one in particular.";
  if (noun == player)
    "You start talking to yourself, but it's a one-sided conversation.";
  if (RunLife(noun, ##Talk))
    rtrue;
  print_ret (The)noun, " ", (IsOrAre)noun, " not very talkative.";
];

[ UnlockSub k;
  if (ObjectIsUntouchable(noun))
    return;
  if (noun hasnt lockable)
  {
    PrintMsg(MSG_UNLOCK_NOT_A_LOCK, 'unlock');
    rtrue;
  }
  if (noun hasnt locked)
  {
    PrintMsg(MSG_UNLOCK_ALREADY_UNLOCKED, 'unlock');
    rtrue;
  }
  k = RunRoutines(noun, with_key);
  if (k == nothing)
    "You can't see how to unlock ", (ItOrThem)noun, ".";
  if (second == nothing && k ~= nothing && k in player)
  {
    second = k;
    print "(with ", (the)second, ")^";
  }
  if (second == nothing)
    "You don't have the key.";
  if (second ~= k)
  {
    PrintMsg(MSG_UNLOCK_KEY_DOESNT_FIT);
    rtrue;
  }
  give noun ~locked;
  run_after_routines_msg = MSG_UNLOCK_DEFAULT;
  run_after_routines_arg_1 = 'unlock';
];

[ UntieSub;
  if (noun == nothing)
    "What do you want to untie?";
  if (ObjectIsUntouchable(noun))
    return;
  "You can't untie ", (ThatOrThose)noun, ".";
];

[ UseSub;
  if (ObjectIsUntouchable(noun))
    return;
  "You'll have to be more explicit than that.";
];

[ ReviveSub;
  "There's no one here to revive.";
];

End;
