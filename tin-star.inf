Constant Story "Tin Star";
#Ifv5;
Zcharacter table + '@{A9}'; !Add copyright symbol
Constant Headline "^Kenneth Johnson trilogy #2^Copyright @{A9} 2025 Garry Francis & Gianluca Girelli^https://bdb-project.itch.io/tin-star^Type ABOUT for further info and credits.^^";
#Ifnot;
Constant Headline "^Kenneth Johnson trilogy #2^Copyright (c) 2025 Garry Francis & Gianluca Girelli^https://bdb-project.itch.io/tin-star^Type ABOUT for further info and credits.^^";
#Endif;

Array UUID_ARRAY string "UUID://01f08399-607b-41c2-9878-dddb31a25de0//";
#Ifdef UUID_ARRAY;
#Endif;

Release 1;
Serial "250629";

!Inform 6 constants
Constant DEATH_MENTION_UNDO;
Constant MAX_CARRIED = 10;
Constant NO_SCORE;

!PunyInform constants
Constant OPTIONAL_EXTENDED_METAVERBS;
Constant OPTIONAL_EXTENDED_VERBSET;
Constant OPTIONAL_FULL_DIRECTIONS;
#Ifv5;
Constant OPTIONAL_PROVIDE_UNDO;
#Endif;
Constant RUNTIME_ERRORS 0;!0 for release, 2 for debug

!PunyInform static messages
Constant MSG_COMMENT_NO_TRANSCRIPT "Comment recorded. Use SCRIPT ON to save future comments in a transcript.^";
Constant MSG_COMMENT_TRANSCRIPT "Comment recorded.^";
Constant MSG_DIG_NO_USE "You have better things to do than dig for buried treasure.";
Constant MSG_PARSER_NO_INPUT "You need to enter a command.";
Constant MSG_PARSER_UNKNOWN_VERB "That's not a verb I recognise.";
!Constant MSG_PRAY_DEFAULT "You pray that you can find your wife and daughter and they're unharmed.";
Constant MSG_SHOUT_DEFAULT "~Yeehaa!~";
Constant MSG_SING_DEFAULT "~Oh give me a home where the buffalo roam,^Where the deer and the antelope play,^Where seldom is heard a discouraging word,^And the skies are not cloudy all day.~";
Constant MSG_SMELL_DEFAULT "The only thing you can smell is yourself. You haven't had a bath for days.";
Constant MSG_SORRY_DEFAULT "Oh, don't apologise.";
Constant MSG_WAIT_DEFAULT "Time passes...";
Constant MSG_SWIM_DEFAULT "Swimming requires water. Take a look around. Do you see any water here?";
Constant MSG_THINK_DEFAULT "Think Kenneth, think. There must be a way to track those bandits down.";

!PunyInform dynamic messages
Constant MSG_CLOSE_NOT_OPEN 1000;
Constant MSG_LOCK_ALREADY_LOCKED 1001;
Constant MSG_LOCK_CLOSE_FIRST 1002;
Constant MSG_LOCK_KEY_DOESNT_FIT 1003;
Constant MSG_UNLOCK_ALREADY_UNLOCKED 1004;
Constant MSG_UNLOCK_KEY_DOESNT_FIT 1005;

!Replaced actions
Replace GoSub; !Delete if diagonal directions are used
Replace LockSub;
Replace UnlockSub;

Include "globals.h";
Include "ext_cheap_scenery.h";

!Game-specific constants
Constant YOUR "your";
Constant SOME "some";
Constant DESERT_DESCRIPTION "The hot summer sun of the desert reflects on the golden sea of burning sand. The desert extends in every direction, but you can't get your bearings, because the landscape is so similar wherever you turn.";
Constant EERILY_QUIET "The desert is eerily quiet.";
Constant LOST_IN_DESERT "The desert holds many secrets. Examine it and follow what you find there. Listen can also help, sometimes.";

!Game-specific variables
Attribute horsey;
Global p_has_eaten = false;  !player has eaten pemmican
Global p_has_drunk = false;  !player has drunk water
Global h_has_drunk = false;  !horse has drunk water

!========================================
! Entry point routines
!========================================
[ LibraryMessages p_msg p_arg_1 p_arg_2;
  switch (p_msg)
  {
    MSG_CLOSE_NOT_OPEN:
      print_ret (CTheyreOrIts)noun, " already closed.";
    MSG_LOCK_ALREADY_LOCKED:
      print_ret (CTheyreOrIts)noun, " already locked.";
    MSG_LOCK_CLOSE_FIRST:
      "You'll have to close ", (ItOrThem)noun, " first.";
    MSG_LOCK_KEY_DOESNT_FIT:
      print_ret (The)second, " ", (DoesntOrDont)second, " fit the lock.";
    MSG_UNLOCK_ALREADY_UNLOCKED:
      print_ret (CTheyreOrIts)noun, " already unlocked.";
    MSG_UNLOCK_KEY_DOESNT_FIT:
      print_ret (The)second, " ", (DoesntOrDont)second, " fit the lock.";
  }
  p_arg_1 = p_arg_2;
];

Include "puny.h";

!========================================
! Initialisation
!========================================
[ Initialise;
  location = room04;
  lookmode = 2;
  move clothes to player;
  no_implicit_actions = true;
  player.description = PlayerDescription;

  "Where the West begins, where the Great Plains stretch between the Mississippi-Missouri River and the Rocky Mountains, the tin star is the very symbol of the law, and the men who carry it challenge every day the violence and cunning of outlaws with no past and no future.^^After the violence of a group of criminals had almost taken away the life of your wife and daughter, you decided to become one of these ~marshals~.^^For a few years, your life passed quietly and your duties as sheriff were limited to short missions, like escorting outlaws to the state prisons. But one day, the tranquility of Tucson was shattered by the arrival of a group of dangerous bandits whose faces had long decorated the walls of many Union offices. The Bank was their target, and your absence, due to an official mission in El Paso, was their ace in the hole. They arrived shooting and shouting, spreading death and fear everywhere and taking away all the savings of the people of Tucson. Some citizens had fallen under the blows of the bandits and their friends had not even had the chance to bring the bodies back to the city.^^Unable to stand this, you saddled your horse and, after taking with you water, food and ammunition, you set off into the night in pursuit of the bandits, only to fall in their trap. When you woke up, the sun was already high, and hatred and desperation had grown inside you. Your horse was only a few dozen yards away, but you could not reach it, because the bandits had tied your hands and feet. An ordinary man would have ended up slowly dying of thirst under the torrid summer sun, but you are not an ordinary man, and you will soon prove it!^";
];

!========================================
! Classes
!========================================
Class OpenContainer
with
  invent
  [;
    if (inventory_stage == 2 && children(self) == 0)
      rtrue;
  ],
has container open;

!========================================
! Inventory
!========================================
!----------------------------------------
! Clothes
!----------------------------------------
Object clothes "clothes"
with
  article YOUR,
  name 'clothes' 'garments' 'shirt' 'tin' 'star',
  description "You are the sheriff of Tucson and dressed accordingly. Most notable is the tin star on your shirt.",
  before
  [;
    Disrobe:
      "You'd better not. You need your clothes to protect you from the blazing desert sun.";
  ],
has clothing pluralname worn;

!========================================
! Room 1: Desert
!========================================
Object room01 "Desert"
with
  name 'desert',
  description
  [;
    if ((horse in self) && h_has_drunk == false)
    {
      h_has_drunk = true;
      print "As soon as the horse spots the basin, he drinks until his strength is restored. The horse can now be mounted.^^";
    }
    print_ret (string)DESERT_DESCRIPTION;
  ],
  n_to room02,
  s_to room07,
  e_to room02,
  w_to room06,
  before
  [;
    Swim:
      "As much as you would love that, you're not here for leisure.";
    Listen:
      "The sound of running water is soothing.";
  ],
  cheap_scenery
    1 'sand' "The glaring sun turns it into a sea of gold, but there's no richness here - only death."
    1 'sun' "Hot. Relentless.",
has horsey light;

!----------------------------------------
! Desert (floating object)
!----------------------------------------
Object "desert"
with
  name 'desert' 'expanse' 'ocean' 'of' 'fiery' 'sandy' 'landscape',
  description
  [;
    print "The desert is harsh and unforgiving, and hot as Hell itself. ";
    if (location == room04)
      "It's huge, hopeless and deadly. The road peters out to the west.";
    if (hoof_prints in location)
      "You see a faint trace of hoof prints in the sand, possibly left by the bandits you are chasing.";
    else
      "The sun-baked soil is too hard to detect any hoof prints.";
  ],
  each_turn
  [;
    switch (random(50))
    {
      1: "^A vulture flies high in the sky. It may have spotted a dead horse nearby.";
      2: "^A coyote barks somewhere in the distance.";
      3: "^A cloud of desert insects hovers briefly in the air, then flies off.";
      4: "^The silence of the desert is unnerving.";
      5: "^The heat is stifling.";
      6: "^The sun is relentless.";
      7: "^You wipe the sweat from your brow.";
      8: "^You feel a trickle of perspiration running down your back.";
      9: "^Some sort of bug scitters across the parched desert in front of you, then it's gone.";
      10: "^The hot sun beats down on you.";
    }
  ],
  found_in room01 room02 room03 room04 room06 room07 room08 room11 room12 room13 room17,
  !found_in room01 room02,
has scenery;

!----------------------------------------
! Hoof prints (floating object)
!----------------------------------------
Object hoof_prints "hoof prints"
with
  name 'faint' 'trace' 'of' 'hoof' 'print' 'prints' 'track' 'tracks',
  description
  [;
    print "You see a faint trace of hoof prints heading ";
    switch (location)
    {
      room01: "south and west.";
      room02: "west then south.";
      room03: "west.";
      room04: "west.";
      room06: "east.";
      room07: "north. An even fainter trace leads east, but it could be an old one.";
      room08: "west.";
      room11: "south, although there is a confused mass of tracks around the overturned wagon before heading off in that direction.";
      room12: "north.";
      room13: "north then east.";
      room17: "south. Now that the ground is firmer, you can see that they were left by a group of horses. They are still fresh, so they likely belong to the bandits you are chasing.";
    }
  ],
  found_in room01 room02 room03 room04 room06 room07 room08 room11 room12 room13 room17,
has scenery;

!----------------------------------------
! Basin of water
!----------------------------------------
Object basin "basin of water" room01
with
  name 'basin' 'tufts' 'grass',
  description "It's a basin of clear water surrounded by tufts of grass. It looks very refreshing in this desert environment.",
has static;

!----------------------------------------
! Water
!----------------------------------------
Object water "water" room01
with
  name 'water',
  found_in room01 room22,
  before
  [;
    Drink:
      if (p_has_drunk == false)
      {
        p_has_drunk = true;
        room03.turns_active = 0; 
        StopDaemon(room03);
        print "You kneel on the ground and take a drink of water. After what you've been through in the desert, you feel so refreshed.";
        if ((player hasnt general) && (p_has_eaten == true))
        {
          give player general;
          print " You feel your strength coming back.";
        }
      "";
      }
      else "You don't need to drink again.";
    Take:
      if (canteen notin player)
        "You need a container to put it in; something like a canteen so that it doesn't splash all over the place.";
      print "(with the canteen)^";
      if (canteen has general)
        "The canteen is already full.";
      give canteen general;
      "You fill the canteen with water from the basin.";
    ],
has scenery;

!========================================
! Room 2: Desert
!========================================
Object room02 "Desert"
with
  name 'desert',
  description
  [;
    print_ret (string)DESERT_DESCRIPTION;
  ],
  n_to room02,
  s_to room01,
  e_to room07,
  w_to room01,
  before
  [;
    Hint:
      print_ret (string)LOST_IN_DESERT;
    Listen:
      "The sound of water seems to come from the south and from the west.";
  ],
  cheap_scenery
    1 'sand' "The glaring sun turns it into a sea of gold, but there's no richness here - only death."
    1 'sun' "Hot. Relentless.",
has horsey light;

!========================================
! Room 3: Desert
!========================================
Object room03 "Desert"
with
  name 'desert',
  description
  [;
    print_ret (string)DESERT_DESCRIPTION, " To the east, the enormous walls of a canyon mark the edge of the desert and the beginning of the road to Tucson.";
  ],
  n_to room03,
  s_to room03,
  e_to room04,!Conditional
  w_to room08,
  each_turn [; StartDaemon(self); ],
	  turns_active,
	  daemon [;
			if (p_has_drunk == false) {
        switch (++(self.turns_active)) {
          9: "^The heat is unbearable... and your throat is starting to get dry, too dry.";
          14: "^You're exhausted... if you don't drink some water you'll soon collapse.";
          16: "^You need to drink. Now!";
          19: self.turns_active = 0; 
              StopDaemon(self); 
              deadflag = 1;
              "^Your vision blurs, and everything begins to disappear covered by a heavy black veil... you collapse on the burning desert sand...soon you'll be food for the vultures. (The desert is unforgiving. Try RESTART instead of UNDO.)";
        }
      }
		],
    cheap_scenery
    1 'sand' "The glaring sun turns it into a sea of gold, but there's no richness here - only death."
    1 'sun' "Hot. Relentless."
    1 'canyon' "The typical landscape of the Arizona desert. It's indeed beautiful, but you have other things to do rather than sightseeing.",
has horsey light;

!========================================
! Room 4: Huge Rock Walls
!========================================
Object room04 "Huge Rock Walls"
with
  description "Huge rock walls without any support extend from east to west. To the west you can see the desert expanse and to the east, beyond the walls of the canyon, the road to Tucson.",
  w_to room03,!Conditional
  cant_go "Right now, you need to chase those bandits. They fled towards the west.",
  cheap_scenery
    3 'huge' 'rock' 'walls' "They are too steep to be climbed."
    1 'sun' "Hot. Relentless."
    1 'canyon' "The typical landscape of the Arizona desert. It's indeed beautiful, but you have other things to do rather than sightseeing.",
  before
  [;
    Go:
      if (rope has static)
        "You can't go anywhere while you're tied up with that rope.";
    Hint:
      if (rope has static)
        "The rope can be burned, if you manage to rekindle the fire.";
      "You need to find those bandits, so proceed to the west.";
    Listen:
      print_ret (string)EERILY_QUIET;
  ],
has horsey light;

!----------------------------------------
! Horse
!----------------------------------------
Object horse "horse" room04
with
  article "your",
  name 'horse' 'stallion',
  short_name
  [;
    if (tied_rope in self)
    {
      print "horse with a rope tied to it";
      rtrue;
    }
  ],
  description
  [;
    print "He's your faithful stallion";
    if (tied_rope in self)
      print " who currently has a rope tied to him";
    ".";
  ],
  react_before
  [ destination;
    if (player notin self && end_of_rope notin player)
      rfalse;
    if (player in self && action == ##Examine)
      rfalse;
    if (player in self && noun ~= nothing && CommonAncestor(player, noun) == location)
        "You can't reach ", (the)noun, " while you're sitting on your horse.";
    Drop:
      if (player in self && noun in player && noun hasnt worn)
      {
        move noun to location;
!        scope_modified = true; !If using OPTIONAL_MANUAL_SCOPE
        print (The)noun, " fall";
        if (noun hasnt pluralname)
          print "s";
        " to the ground.";
      }
    Go:
      destination = location.(direction_properties_array->selected_direction_index);
      if (destination ofclass Object)
      {
        if (destination has door || destination hasnt horsey)
          "You can't take the horse that way. You'll have to leave him behind.";
        else
          move self to destination;
      }
  ],
  before
  [ destination;
    Enter:
      if (rope has static)
        "Aren't you still tied up?";
      if (player hasnt general)
         "You're too weak to mount your horse right now. You need to drink some water first.";
      if (h_has_drunk == false)
        "Your stallion is too weak to be mounted. He needs to have some water first.";
    Go:
      destination = location.(direction_properties_array->selected_direction_index);
      if (destination ofclass Object)
      {
        if (destination has door || destination hasnt horsey)
        {
          print "You can't take the horse that way. You'll have to leave him behind.^";
          return 2;
        }
        return 1;
      }
  ],
  after
  [;
    Enter:
      "You mount your horse.";
    Exit, GetOff:
      "You dismount your horse.";
  ],
has animate enterable supporter;

!----------------------------------------
! Rope
!----------------------------------------
Object rope "rope" room04
with
  name 'rope',
  description
  [;
    print "It's a long rope";
    if (self has static)
      print " that ties you up";
    ".";
  ],
  react_before
  [;
    Take:
      if (self has static)
        "You can't take anything while you're tied up.";
  ],
  before
  [;
    Burn:
      !if (location ~= room04 || coals in nothing)
      if (location ~= room04 || coals hasnt light)
        "You don't see a source of heat intense enough to burn the rope.";
      if (self hasnt static)
        "Don't burn any more of it. It might come in useful.";
      give self ~static;
      "You edge closer to the fire and burn the rope just enough to free yourself.";
    Tie:
      if (second == nothing && horse in location)
      {
        print "(to your horse)^";
        second = horse;
      }
      if (second == nothing)
        "You'll have to tell me what to tie it to.";
      if (second ~= horse)
        "You can't tie the rope to ", (the)second, ".";
      if (horse notin location)
        "Your horse is not here.";
      remove self;
      move tied_rope to horse;
      move end_of_rope to player;
      PronounNotice(tied_rope);
      "You tie the rope to your horse and grab the other end. He will now follow you around when you're holding the rope.";
    Untie:
      if (self has static)
        "This may come as a surprise to you, but you can't untie it while you're tied up.";
  ],
has static;

!----------------------------------------
! Tied rope
!----------------------------------------
Object tied_rope "rope tied to your horse"
with
  name 'end' 'of' 'rope' 'tied',
  description
  [;
    print "It's a short rope tied to your horse. As you're ";
    if (end_of_rope notin player)
      print "not ";
    print "holding the end of the rope, your horse will ";
    if (end_of_rope notin player)
      print "not ";
    "follow you.";
  ],
  before
  [;
    Drop:
      if (end_of_rope notin player)
        "You're not holding it.";
      remove end_of_rope;
      "You drop the end of the rope, so that your horse will no longer follow you.";
    Take:
      if (end_of_rope in player)
        "You're already holding the rope.";
      move end_of_rope to player;
      "You grab the other end of the rope so that your horse will follow you.";
    Tie:
      "It's already tied to your horse.";
    Untie:
      remove self;
      if (end_of_rope in player)
        remove end_of_rope;
      move rope to player;
      PronounNotice(rope);
      "You untie the rope from your horse, so it will no longer follow you.";
  ],
has scenery;

!----------------------------------------
! End of rope
!----------------------------------------
Object end_of_rope "end of a rope tied to your horse"
with
  article "the",
has;

!----------------------------------------
! Remains of a campfire
!----------------------------------------
Object campfire "remains of a campfire" room04
with
  article "the",
  name 'remains' 'of' 'fire' 'campfire',
  description
  [;
    print "It's the remains of a campfire. ";
    if (coals hasnt light)
      "The coals are still warm.";
    else
      "There are some hot coals burning in the fire.";
  ],
  before
  [;
    Blow:
      <<Blow coals>>;
    Receive:
      "You'd better not put anything in the campfire or it might get burnt.";
  ],
has container open static;

!----------------------------------------
! Coals
!----------------------------------------
Object coals "coals" campfire
with
  name 'coals' 'ashes',
  description
  [;
    if (self hasnt light)
      "The coals are still warm.";
    else
      "When you blew on the coals, a flame sparked into life and it's still burning.";
  ],
  before
  [;
    Blow:
      if (self hasnt light)
      {
        give self light;
        "You blow on the warm coals and a flame suddenly lights up.";
      }
      give self ~light;
      "You blow the flame out. That was pretty silly.";
    Take:
      "They're too hot to take.";
    Touch:
      "They're too hot to touch.";
  ],
has pluralname static;

!----------------------------------------
! Old blanket
!----------------------------------------
Object blanket "old blanket" room04
with
  article "an",
  name 'old' 'blanket',
  description "It is an Indian blanket, useful to shield yourself from cold desert nights, and to make smoke signals should the need arise.",
  invent
  [;
    if (inventory_stage == 2)
      if (smoke_signals notin nothing)
        print " (now stinking like a barbecue)";
  ],
has;

!========================================
! Room 5: Tunnel
!========================================
Object room05 "Tunnel"
with
  name 'tunnel',
  description "In the darkness of the tunnel, silence gives way to a typical ticking. The gallery is threatened by dangerous water infiltrations, and the mud covering the ground confirms it. To the south, you can see the dense network of galleries you have passed through, in which silence and darkness reign.",
  s_to room10,
  before
  [;
    Listen:
      if (noun == nothing)
        "A faint sound seems to come from the south.";
  ],
has;

!----------------------------------------
! Navajo hatchet
!----------------------------------------
!EXAMINE GALLERIES to find this
Object item29 "Navajo hatchet" room05
with
  name 'navajo' 'hatchet' 'axe' 'tomahawk',
  description "It is single-handed axe with a straight shaft and a head made of iron.",
  before [;
    Take:
      move item29 to player;
      move large_branch to player;
      move torch to limbo; 
      "As you take the hatchet you slide on the mud and the torch falls in the water, extinguishing itself. You are now in the dark.";
  ],
has;

!========================================
! Room 6: Desert
!========================================
Object room06 "Desert"
with
  name 'desert',
  description
  [;
    print_ret (string)DESERT_DESCRIPTION;
  ],
  n_to room01,
  s_to room06,
  e_to room11,
  w_to room17,
  cheap_scenery
    1 'sand' "The glaring sun turns it into a sea of gold, but there's no richness here - only death."
    1 'sun' "Hot. Relentless.",
has horsey light;

!========================================
! Room 7: Desert
!========================================
Object room07 "Desert"
with
  name 'desert',
  description
  [;
    print_ret (string)DESERT_DESCRIPTION;
  ],
  n_to room01,
  s_to room08,
  e_to room02,
  w_to room13,
  before
  [;
    Hint:
      print_ret (string)LOST_IN_DESERT;
    Listen:
      "The sound of water seems to come from the north.";
  ],
  cheap_scenery
    1 'sand' "The glaring sun turns it into a sea of gold, but there's no richness here - only death."
    1 'sun' "Hot. Relentless.",
has horsey light;

!========================================
! Room 8: Desert
!========================================
Object room08 "Desert"
with
  name 'desert',
  description
  [;
    print_ret (string)DESERT_DESCRIPTION;
  ],
  n_to room07,
  s_to room12,
  e_to room03,
  w_to room13,
  cheap_scenery
    1 'sand' "The glaring sun turns it into a sea of gold, but there's no richness here - only death."
    1 'sun' "Hot. Relentless.",
has horsey light;

!========================================
! Room 9: Mining Tunnels
!========================================
Object room09 "Mining Tunnels"
with
  name 'intricate' 'network' 'of' 'mining' 'tunnels',
  description "You're lost in an intricate network of mining tunnels. You try to project the light of your crude torch far away, but the darkness of the passages swallows it up from every side. In the silence, you seem to hear a distant dripping, but you can't figure out which direction it's coming from.",
  n_to room10,
  s_to room14,
  e_to room09,
  w_to room09,
has;

!========================================
! Room 10: Mining Tunnels
!========================================
Object room10 "Mining Tunnels"
with
  name 'intricate' 'network' 'of' 'mining' 'tunnels',
  description [;
    if (torch in player)
      "You're lost in an intricate network of mining tunnels. You try to project the light of your crude torch far away, but the darkness of the tunnels swallows it from every side. In the silence, you seem to hear a distant dripping, but you can't figure out which direction it's coming from.";
    "Now that your eyes are adapting to the darkness, you can see the outline of an exit door towards the east.";
  ],
  n_to room05,
  s_to room10,
  e_to 0,
  w_to room09,
  before [;
    Listen:
      if (noun == nothing)
        "A distant dripping seems to come from the north.";
  ],
has light;

!----------------------------------------
! exit door
!----------------------------------------
Object fake_door " exit door" room10
with
  name 'exit' 'door',
  description
  [;
    if (torch in player)
      "You just see tunnels everywhere.";
    if (self has general)
      "You chopped it down with the Navajo hatchet, and it's not blocking your way anymore.";
    else
      "It is made of wood and seems to be locked from the outside. It cannot be opened. The wood is starting to rot due to the humidity of the environment.";
  ],
  before [;
      Open:
        if( self hasnt general)
          "The door is warped and stuck, so it can't be opened. Since the wood is rotting, you might be able to cut it, should you have the right tool.";
        "You cut it down with the hatchet, so it's already open.";
      Attack, Cut:
      if (self has general)
        "You already opened your way out to the east.";
      if (second == nothing && item29 in player)
      {
        print "(with the hatchet)^";
        second = item29;
      }
      give self general;
      room10.e_to = room37;
      "Using the hatchet you just found, you chop down the door in tiny little pieces. The way out is now accessible going east.";
  ],
has scenery;

!========================================
! Room 37: Mining Tunnels
!========================================
Object room37 "Mining Tunnels"
with
  name 'intricate' 'network' 'of' 'mining' 'tunnels',
  description [;
    if (torch in player)
      "The cave you came from is north of your position while to the south, beyond the entrance, a large open space can be spotted.";
    "The cave you came from is north of your position while a faint light can be seen towards the south at the end of the tunnel. Is it freedom, or just the headlamp of an incoming train?";
  ],
  n_to room10,
  s_to room15,
  e_to room37,
  w_to room37,
  before [;
    Listen:
      if (noun == nothing)
        "Faint sounds of wind and animals seem to come from the south.";
  ],
has light;

!========================================
! Room 11: Desert
!========================================
Object room11 "Desert"
with
  name 'desert',
  description
  [;
    print_ret (string)DESERT_DESCRIPTION;
  ],
  n_to room06,
  s_to room17,
  e_to room11,
  w_to room17,
  cheap_scenery
    1 'sand' "The glaring sun turns it into a sea of gold, but there's no richness here - only death."
    1 'sun' "Hot. Relentless.",
has horsey light;

!----------------------------------------
! Overturned wagon
!----------------------------------------
Object item15 "overturned wagon" room11
with
  article "an",
  name 'overturned' 'wagon',
  description
    [;
      print "This wagon was possibly used for transporting goods across the desert. ";
      if (dynamite in nothing)
        "It might be worth searching the wagon.";
        else
          "You've already searched the wagon, so it's not worth searching it again.";
    ],
    before
    [;
      Search:
        print "You search the wagon";
        if (dynamite in nothing)
        {
          move dynamite to room11;
         " and find a stick of dynamite.";
        }
        ", but don't find anything of interest.";
    ],
has static;

!----------------------------------------
! Stick of dynamite
!----------------------------------------
Object dynamite "stick of dynamite"
with
  name 'stick' 'of' 'dynamite',
  description 
  [;
    print "It's a red stick of dynamite with a long fuse. It is powerful enough to ";
    if (room20 has visited)
      "free the mine entrance.";
    "blow away large chunks of rock.";
  ],
  before
  [;
    Burn:
      if (self has light)
        "It's already lit.";
      if (second == nothing && torch in player)
      {
        print "(with the torch)^";
        second = torch;
      }
      if (second == nothing)
        "You'll have to tell me what to light it with.";
      if (second ~= torch)
        "You can't light the dynamite with ", (ThatOrThose)second, ".";
      if (self in player)
        "Are you crazy? God said the meek shall inherit the Earth, not the idiots! You'd better drop the dynamite before lighting it unless you want to meet your maker.";
      if (location ~= room20)
        "You only have one stick of dynamite and you can't see anything worth blowing up around here. I think you should save it until you need it.";
      if (self notin small_hole)
        "If you're trying to blow up the entrance of the mine, the dynamite would be more effective if it was placed in the hole. Have you examined it carefully?";
      give self light;
      StartTimer(self, 3);
      "The wick of the dynamite is now burning like a sparkler. You'd better get out of here before it blows up!";
    Blow, Extinguish:
      if (self hasnt light)
        "It's not lit.";
      "Too late. You can't stop the inevitable.";
    Take:
      if (self has light)
        "Are you crazy? Get out of here before it blows up!";
  ],
  time_out
  [;
    move dynamite to limbo;
    move large_hole to room20;
    move item17 to room20;
    give room20 general;
    give landslide general;
    give mine general;
    room20.n_to = room14;
    room20.in_to = room14;
    if (player in room20)
    {
      deadflag = 1;
      "^KABOOM! The dynamite blows up the rocks that closed the entrance of the mine. Also, it blows up the stupid sheriff who wasn't smart enough to get out of here, despite being told to do so. St Peter is waiting for you.";
    }
    "^KABOOM! You hear an explosion nearby. You can now inspect the damage.";
  ],
  time_left 3,
has;

