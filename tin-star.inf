      "You can't enter it since a landslide covered the entrance.";
    "After the explsion, there is now an opening in the landslide, and you can enter the mine.";
  ],
has scenery;

!----------------------------------------
! Small hole
!----------------------------------------
Object small_hole "small hole" room20
class OpenContainer
with
  name 'small' 'hole' 'soil',
  description
  [;
    print "It's a small hole, about the width of a candle, possibly caused by the erosion. ";
    <<Search self>>;
  ],
  before
  [;
    Receive:
      if (noun ~= dynamite)
        print_ret (The)noun, " won't fit in the hole.";
  ],
has container open scenery;

!----------------------------------------
! Large hole in the mountain wall
!----------------------------------------
Object large_hole "large hole in the mountain wall"
with
  parse_name
  [ i;
    while (NextWord() == 'large' or 'hole' or 'in' or 'the' or 'mountain' or 'wall')
      i++;
    return i;
  ],
  description "Wow. The stick of dynamite sure blew a big hole here.",
  before
  [;
    Enter:
      <<Go FAKE_N_OBJ>>;
  ],
has static;

!----------------------------------------
! Debris around the entrance to the mine
!----------------------------------------
Object item17 "debris around the entrance to the mine" !room20
with
  article "lots of",
  name 'debris' 'entrance' 'to' 'mine',
  description "A whole amount of debris; they are the result of the explosion.",
has static;

!========================================
! Room 21: South Side of Ravine
!========================================
Object room21 "South Side of Ravine"
with
  name 'south' 'side' 'of' 'ravine',
  description "You are on the south side of a ravine, in the middle of a group of enormous rocks. To the south, you can clearly see the smoke of a campfire, while to the north a makeshift bridge allows you to reach the other side of the chasm.",
  n_to room15,
  s_to room27,
has light;

!========================================
! Room 22: In Front of White Buildings
!========================================
Object room22 "In Front of White Buildings"
with
  name 'bare' 'white' 'buildings',
  description "Bare white buildings placed one next to the other look at you with their black windows like skulls with empty eye sockets. The place is silent, but on the ground you can distinguish numerous horse hoofprints and human footprint all around, especially in front of one of the buildings. You can get in by going north. Towards the south you go back  from where you came.",
  in_to room16,
  n_to room16,
  s_to room28,
  e_to "You are on foot, alone, and in a open range. It is better not to venture that way.",
  cheap_scenery
			1 'footprints' "It looks like they were left by a numerous group of people. They are pretty recent, so chances are those guys will be back soon."
      3 'hoofprints' 'hoof' 'prints' "They were left by a group of horses, and head towards the east.",
has light;

!----------------------------------------
! watering trough
!----------------------------------------
Object trough "watering trough" room22
with 
  name 'watering' 'horse' 'trough',
  description [;
    print "It is a long, shallow container from which horses drink. It's full of water";
    "";
    !<<Search self>>;
  ],
  before
  [;
    Receive:
      "Only water can be put in the canteen.";
  ],
  has container open static;

!----------------------------------------
! hitching rails
!----------------------------------------
Object rails "hitching rails" room22
with 
  article "a couple of",
  name 'hitching' 'rails',
  description "Made of wood, they are horizontal rails with vertical supports to which a horse can be hitched, or tied up to.",
has static;

!----------------------------------------
! Band of bandits on horseback
!----------------------------------------
Object item32 "band of bandits on horseback" !room22
with
  article "the",
  name 'band' 'of' 'bandits',
  description "Those are the bandits you were looking for.",
  before [;
    Shoot:
        if (rifle notin player)
        {
          deadflag = 1;
          "You do not have any weapon with you, so the bandits are the only one opening fire. Their bullets hit you multiple time and you fall mortally wounded on the ground. A blood-stained tin star is the last thing you see. And then, nothing ...";
        }
        if (second == nothing && rifle in player)
        {
          print "(with the rifle)^";
          <<Shoot self rifle>>;
        }
        deadflag = 1;
        "You try to shoot the bandits but, despite your skills and how fast you are, they are just too many. Their bullets hit you multiple times and you fall mortally wounded on the ground. A blood-stained tin star is the last thing you see. And then, nothing ...";
  ],
has animate pluralname;

!========================================
! Room 23: Foot of Mountain Range
!========================================
Object room23 "Foot of Mountain Range"
with
  name 'foot' 'of' 'long' 'mountain' 'range',
  description "You have reached the foot of a long mountain range that marks the western border of the Sierra. To the south a rocky expanse disappears into the distance, while to the east you can see the immense sunny expanse of the Sierra.",
  s_to room29,
  e_to room24,
has horsey light;

!========================================
! Room 24: Sierra Sedona
!========================================
Object room24 "Sierra Sedona"
with
  name 'sierra' 'sedona',
  description "You are crossing the Sierra Sedona, which continues to the north, borders the Great Plains to the east, ends at the foot of a mountain range to the west and transforms into a barren and inhospitable region to the south.",
  n_to room18,
  s_to room30,
  e_to room19,
  w_to room23,
has horsey light;

!----------------------------------------
! Dead tree
!----------------------------------------
Object tree "dead tree" room24
with
  name 'dead' 'tree',
  description [;
    print "It's an old, spooky dead tree. ";
    if (self hasnt general)
      "A large branch, almost completely detached, is hanging from it. ";
    "Now that you took the branch it looks even spookier.";
  ],
has static supporter;

!----------------------------------------
! Large branch
!----------------------------------------
Object large_branch "large branch" tree
with
  name 'large' 'branch',
  description "A dried-up large branch. Maybe you could use it as a torch, if needed.",
  before
  [;
    Take:
      if (self hasnt moved)
      {
        move self to player;
        give tree general;
        "You take the large branch.";
      }
      "You already took the large branch.";
     
    Burn:
      if (location == room30 || location == 27 || (location == room04 && coals has light) || (location == room35 && makeshift_fire notin nothing))
      {
        move torch to parent(self);
        move self to limbo;
        "You light up the branch, making a crude lit torch.";
      }
  ],
has;

!----------------------------------------
! Crude lit torch
!----------------------------------------
Object torch "crude lit torch" !room00
with
  name 'crude' 'lit' 'torch',
  description "It is a simple crude lit torch. It won't last long, but for the time being it seems to hold up.",
  before
  [;
    Extinguish:
      move large_branch to parent(self);
      move self to limbo;
      "You blow out the torch so that it reverts back to a large branch.";
  ],
has light;

!========================================
! Room 25: Grassy Plains
!========================================
Object room25 "Grassy Plains"
with
  name 'green' 'grass' 'grassy' ,
  description "The green expanse of grass sways like a sea of jade in the light breeze blowing from the south. Scanning the landscape in that direction, you see, in the distance, a plateau. To the north, the prairie extends for a long stretch.",
  n_to room19,
  s_to room31,
has horsey light;

!========================================
! Room 26: Large Plateau
!========================================
Object room26 "Large Plateau"
with
  name 'large' 'plateau',
  description "Crossing the long suspension bridge, you have reached a large plateau that extends north. To the south, beyond the rope bridge, you can see the other side of the ravine you crossed.",
  n_to room20,!Conditional
  s_to room32,!Conditional, also CROSS BRIDGE
  before
  [;
    Go:
      if (selected_direction == s_to && item28 in self)
        "The Indians won't let you pass.";
  ],
has light;

!========================================
! Room 27: campfire among Rocks
!========================================
Object room27 "Campfire among Rocks"
with
  name 'campfire' 'among' 'rocks',
  description "You have reached a campfire among the rocks. To the north, beyond the group of rocks you passed, a large chasm opens up. To the east, instead, you see a road to a pueblo.",
  n_to room21,
  e_to room28,
has light;

!========================================
! Room 28: Road to Pueblo
!========================================
Object room28 "Road to Pueblo"
with
  name 'road',
  description "You have set off on the road that leads north to an abandoned pueblo. To the west you can see the smoke of a campfire.",
  n_to room22,
  w_to room27,
has light;

!========================================
! Room 29: Edge of Crevasse
!========================================
Object room29 "Edge of Crevasse"
with
  name 'edge' 'of' 'deep' 'natural' 'crevasse',
  description "You have reached the edge of a deep natural crevasse. To the east opens a sandy territory, very similar to the desert, while to the north a mountain range borders the Sierra. A steep path leads down to the bottom of the crevasse.",
  n_to room23,
  e_to room34,
  d_to room33,!Conditional
has horsey light;

!----------------------------------------
! Mescalero Apaches
!----------------------------------------
Object item28 "Mescalero Apaches" !room26
with
  article "a group of",
  name 'group' 'of' 'mescalero' 'apaches' 'indians',
  description "This is one of the groups of Mescalero that usually raid the region. For some reason, they are not posing a direct threat to you. Unless you do something stupid.",
  life [;
    Attack:
      deadflag = 1;
      if (location == room29)
        "You attack the Mescalero with your weapon, but they are too numerous... your scalp will soon become a warrior's ornament.";
      if (location == room36)
        "With savage howls the Apaches throw themselves at you... you can't even scream.";
    Ask:
        "The Mescalero stare at you. If they undesrtand what you are saying, they sure don't want to reply.";
  ],
  before [;
      Shoot:
        deadflag = 1;
        if (location == room29)
          "You open fire on the Mescalero, but they are too numerous... your scalp will soon become a warrior's ornament.";
        if (location == room36)
          "With savage howls the Apaches throw themselves at you... you can't even scream.";
      Talk:
        "~Go away, white man. You are not welcome here.~";
  ],
  found_in
  [;
    if ((location == room36) || ((location == room29) && (headdress has moved)))
      rtrue;
  ],
has animate pluralname;

!========================================
! Room 30: In Front of Teepee
!========================================
Object room30 "In Front of Teepee"
with
  name 'teepee' 'tepee' 'tipi',
  description "A light breeze stirs the sparse tufts of grass that cover the barren territory on which you find yourself. A teepee stands in the middle of the desolation of the landscape, almost as if to challenge its arid climate, and in front of it an old Indian warms himself in front of a fire singing the ancient songs of his people.",
  n_to room24,
  before
  [;
    Listen:
      "You only hear the crackling sound made by the burning fire.";
  ],
has horsey light;

!----------------------------------------
! teepee
!----------------------------------------
Object teepee "teepee" room30
with
  name 'conical' 'tent' 'teepee',
  description "This typical conical tent has seen better days. Now it's old and battered like the man who inhabits it, but it keeps standing still.",
has static;

!----------------------------------------
! Makeshift fire
!----------------------------------------
Object fire "small fire that burns with a crackling sound" with
  name 'makeshift' 'fire' 'smoke',
  description "The fire warms you up and gives you hope. For a brief moment you wished this was all a dream, but you have to find those bandits.",
  found_in room30 room27,
has static;

!----------------------------------------
! The old Indian
!----------------------------------------
Object indian "old Indian" room30
  with
    article "an",
    name 'old' 'indian' 'man',
      description "The old man looks like someone who has stood beside his warriors in countless battles.",
    life [;
      Ask:
        switch (second)
        {
          'apaches', 'mescalero':
            "~They are a great danger, and an enemy of the Navajo nation. Stay away from them. They can be seen near the Plateau, and use smoke signals to communicate that everything is fine.~";
          'bandits', 'outlaws', 'criminals':
            "~This place is full of those bad people, but the ones you are searching are probably hiding farther east, beyond the Grassy Plains. Beware of them.~";
          'smoke', 'signals', 'smoke signals':
            "~A group of Mescalero will usually send smoke signals to indicate the place is free of intruders. The others will then keep a distance to search somewhere else.~";
          default:
            "~I don't know anything about it.~";
        }
      Show:
        if (noun ~= headdress)
          "The old indian doesn't seem interested in ", (the)noun, ".";
      "The old indian gives a wry smile at the sight of the headdress since he knows its value.";
      Attack:
        "Please don't be silly.";
      Talk:
        "The old man looks at you with a puzzled face. He probably doesn't speak your language very well. Try asking more specific questions.";
    ],
  has animate;

!----------------------------------------
! Navajo knife
!----------------------------------------
Object knife "Navajo knife"
with
  name 'Navajo' 'knife',
  description "A big and sharp Navajo knife.",
has;

!========================================
! Room 31: Rocky Path
!========================================
Object room31 "Rocky Path"
with
  name 'rocky' 'path',
  description "A steep, rocky path winds up to a vast plateau, blending into the green of the Great Plains to the north.",
  n_to room25,
  u_to room35,
has horsey light;

!========================================
! Room 32: Rope Bridge
!========================================
Object room32 "Rope Bridge"
with
  name 'rope' 'bridge',
  description "Below you, between the high rocky walls of the gorge, a raging torrent rushes away in a south-east direction. The fragile rope bridge sways under your weight, and you barely manage to keep your balance, as you stare, not without a little fear, into the abyss beneath your feet.",
  n_to room26,
  s_to room36,
has light;

!========================================
! Room 33: Bottom of Crevasse
!========================================
Object room33 "Bottom of Crevasse"
with
  name 'bottom' 'of' 'crevasse',
  description "The bottom of the crevasse is littered with rocks and debris, and in some places it also hosts a few stunted tufts of grass. The only way out is a steep path up.",
  u_to room29,
has light;

!----------------------------------------
! Navajo headdress
!----------------------------------------
Object headdress "Navajo headdress" room33
with
  name 'navajo' 'headdress',
  description "This eagle-feather headdress, also called a war bonnet, is traditionally a symbol of power and authority reserved for highly respected Native American men. It surely belongs to a chief.",
  before
  [;
    Give:
      if (location == room30)  
        if (noun == headdress)
        {
          move headdress to indian;
          give indian general;
          move knife to player;
          !move item28 to room29; !Mescalero Apaches
          "The old Indian seems happy with your offer, even if the impassivity of his wrinkled face doesn't reveal his emotions. He takes a knife from a fold in his clothing and offers it to you. You gratefully accept it.";
        }
      else 
        "The headdress is an important item. Make sure to give it to the right person.";
  ],
has clothing;

!========================================
! Room 34: Sandy Terrain
!========================================
Object room34 "Sandy Terrain"
with
  name 'vast' 'arid' 'sandy' 'desert-like' 'terrain',
  description "You are on a vast, arid, sandy, almost desert-like terrain. Some dry bushes roll in the wind, often getting stuck in piles of branches or in the rocks to the west, where, over the edge of a deep crevasse, you can see the peaks of the mountains.",
  w_to room29,
has horsey light;

!----------------------------------------
! Dead branches
!----------------------------------------
Object item25 "dead branches" room34
with
  name 'dead' 'branches',
  description "These dead branches could come in useful to make a fire.",
  before
  [;
    Burn:
      if (location ~= room35)
        "You'd better save those branches for later.";
      if (torch notin player)
        "You need an open flame to light the branches.";
      if (self in player)
        "Maybe you should drop the branches, first. You don't want to turn into a torch yourself.";
      move self to limbo;
      move makeshift_fire to room35;
      "You light up the dead branches, making a fire that burns with a crackling sound and produces a lot of smoke.";
  ],
has pluralname;

!----------------------------------------
! Man tied to stake
!----------------------------------------
Object man "man" room34
with
  name 'man' 'tied' 'hand' 'and' 'foot',
  short_name
  [;
    print "man";
    if (ties has scenery)
      print " tied to a stake";
    rtrue;
  ],
  description
  [;
    print "This man looks like yet another victim of those criminals";
    if (ties has scenery)
      ". You can see that he's tied firmly to the stake by some leather ties around his hands and feet.";
    else
      ", but he's doing much better now that you've set him free.";
  ],
  before 
  [;
    Revive, Wake:
      if (self has general)
        "He's doing fine, now. There is no need to revive him again.";
      if (ties has scenery)
        "You should free him from those ties first.";
      if ((canteen notin player) || (canteen hasnt general))
        "You need to have some water to revive him.";
      give self general;
      move rifle to player;
      give canteen ~general;
      "You move the man far from direct sunlight. Then, you help him to drink until the canteen is empty. After a few minutes he is back to his senses, and your gesture has earned you the eternal gratitude of this man.^^~Thank you, my friend. I do not know how to repay you. Ah! I see that you are unarmed.~ He disappears behind the rocks and reappears with a rifle. At first, you think he's going to shoot you, but he gives you the rifle.^^~I had hidden this before being attacked by a group of bandits. I see from your tin star that you're a sheriff. If you can find those bandits, this rifle may come in handy. Before the bandits surprised me, I noticed some smoke signals from Mescalero Apaches above the plateau. The bandits headed that way. Be careful and good luck, my friend.~";
  ],
  life [;
      Ask:
        if (ties has general)
          "Perhaps it would be better to free the poor man, first.";
        if (self hasnt general)
          "He is unconscious ... what about reviving him first?";
        switch (second)
        {
          'apaches', 'mescalero':
            "~They are a great danger. Stay away from them. They can be seen near the Plateau, and use smoke signals to communicate that everything is fine.~";
          'bandits', 'outlaws', 'criminals':
            "~The men you are looking for are possibly the same who did this to me. I head them saying their hideout is farther east, beyond the Grassy Plains. They insulted me in English, but mostly spoke in Spanish to each other.~";
          'smoke', 'signals', 'smoke signals':
            "~A group of Mescalero will usually send smoke signals to indicate the place is free of intruders. The others will then keep a distance to search somewhere else.~";
          default:
            "~I don't know anything about it.~";
        }
      Attack:
        "Please don't be silly.";
      Talk:
        if (ties has general)
          "Perhaps it would be better to free the poor man, first.";
        if (self hasnt general)
          "He is unsconscious ... what about reviving him first?";
        "~I will forever be grateful for saving me. Do you want to ask me a specific question?~";
    ],
has animate;

!----------------------------------------
! Stake
!----------------------------------------
Object stake "stake" room34
with
  name 'stake',
  description
  [;
    print "The stake is firmly buried into the ground. The man ";
    if (self has scenery)
      "is bound to it by leather ties.";
    else
      "was bound to it until you set him free.";
  ],
has scenery;

!----------------------------------------
! Ties
!----------------------------------------
Object ties "leather ties" room34
with
  name 'leather' 'ties',
  description
  [;
    if (self has scenery)
      "Those bandits used wet leather ties to tie this man to the stake. As the leather dries, the ties get shorter and cut into his flesh.";
    else
      "They're the leather ties that the bandits used to tie the man to the stake.";
  ],
  before
  [;
    Cut:
      if (self hasnt scenery)
        "You've already cut them.";
      if (second == nothing && knife in player)
      {
        print "(with the knife)^";
        second = knife;
      }
      if (second == nothing)
        "You'll have to tell me what to cut them with.";
      if (second ~= knife)
        "You'll need something sharper than ", (a)second, ".";
      give ties ~scenery;
      give stake ~scenery static;
      "You cut the leather ties with the knife and they fall to the ground. The man is barely alive, but you'd better revive him, before it's too late.";
    Untie:
      if (self has scenery)
        "After shrinking in the hot sun, they're too tight to untie.";
      else
        "You've already cut them, so there's no need to untie them.";

  ],
has pluralname scenery;

!----------------------------------------
! Winchester rifle
!----------------------------------------
Object rifle "Winchester rifle"
with
  name 'loaded' 'winchester' 'rifle',
  description "It's a loaded Winchester rifle. This is exactly what you need to shoot a target from a safe distance.",
has;

!========================================
! Room 35: Plateau
!========================================
Object room35 "Plateau"
with
  name 'plateau',
  description "You have reached the surface of a vast plateau that extends from the east to a precipice. A stony path descends to the plains.",
  e_to room36,
  d_to room31,!Conditional
has horsey light;

!----------------------------------------
! Makeshift fire
!----------------------------------------
Object makeshift_fire "makeshift fire that burns with a crackling sound and produces a lot of smoke" !room35
with
  name 'makeshift' 'fire' 'smoke',
  description "An intense smoke rises from the fire. Just what you need to make smoke signals.",
has static;

!----------------------------------------
! Smoke signals
!----------------------------------------
Object smoke_signals "smoke signals"
with
  article SOME,
  parse_name
  [ nw i;
    nw = NextWord();
    while (nw == 'smoke' or 'signal' or 'signals')
    {
      i++;
      nw = NextWord();
    }
    return i;
  ],
  description "They are the signals you made to fool the Mescalero into moving in a different region of the Plateau. Now you should be able to cross the rope bridge on the chasm.",
  invent
  [;
    if (inventory_stage == 2)
      print " (rising up in the sky)";
  ],
  before
  [;
    Make:
      if (location ~= room35)
        "You have no reason to send smoke signals from this location.";
      if (self notin nothing)
        "You've already made the smoke signals.";
      if (makeshift_fire in nothing)
        "You need smoke to make smoke signals, and you cannot have smoke if you haven't a fire.";
      !if (~~TestScope(blanket))
      if (blanket notin player)
        "Something like a blanket woould prove useful to send those signals.";
      if (second == nothing && blanket in player)
      {
        print "(with the blanket)^";
        second = blanket;
      }
      move smoke_signals to location;
      give item28 absent;
      room36.n_to = room32;
      "You lean down and, using the blanket, you partially cover the fire a couple of times so to send two distinctive puffs of smoke. This is the standard signal for ~all is well~ and, turning your gaze towards the east, you see the Mescalero riding away. They are gone, now, and you can proceed with your quest.";
  ],
has static;

!========================================
! Room 36: Edge of Chasm
!========================================
Object room36 "Edge of Chasm"
with
  name 'edge' 'of' 'wide' 'deep' 'chasm',
  description "A wide, deep chasm opens up towards the north, at the bottom of which you can clearly see the rapids of a stream. A long, unstable rope bridge leads to the other side of the chasm. To the west, a plateau extends as far as your gaze can see.",
  n_to "A group of Mescalero Apaches are blocking your way. You need to send them off before proceeding.",
  w_to room35,
has horsey light;

!========================================
! Limbo
!========================================
! a fictitious place where to move objects not needed anymore
Object limbo;

!========================================
! Printing rules
!========================================
[ consultWord word i;
  for (i=0:i<WordLength(word):i++)
    print (char)LowerCase(WordAddress(word)->i);
];

[ DoesntOrDont obj;
  if (obj has pluralname)
    print "don't";
  else
    print "doesn't";
];

[ firstConsultWord word i;
  for (i=0:i<WordLength(word):i++)
    if (i == 0)
      print (char)UpperCase(WordAddress(word)->i);
    else
      print (char)LowerCase(WordAddress(word)->i);
];

!========================================
! Other routines
!========================================
[ LowerCase c; ! for ZSCII matching ISO 8859-1
  switch (c)
  {
    'A' to 'Z': c = c + 32;
    202, 204, 212, 214, 221: c--;
    217, 218: c = c - 2;
    158 to 160, 167, 168, 208 to 210: c = c - 3;
    186 to 190, 196 to 200: c = c - 5 ;
    175 to 180: c = c - 6;
  }
  return c;
];

[ UpperCase c; ! for ZSCII matching ISO 8859-1
  switch (c)
  {
    'a' to 'z': c = c - 32;
    201, 203, 211, 213, 220: c++;
    215, 216: c = c + 2;
    155 to 157, 164, 165, 205 to 207: c = c + 3;
    181 to 185, 191 to 195: c = c + 5 ;
    169 to 174: c = c + 6;
  }
  return c;
];

[ PlayerDescription;
  print "Your name is Kenneth Johnson and you're the sheriff of Tucson. You're on the trail of the bandits that robbed the bank in Tucson. It's a dangerous undertaking, but it's your duty to catch them.";
  if (rope has static)
    print " You're currently tied up with a rope. You'll have to get yourself untied if you expect to catch those bandits. If you don't, you'll fry in the desert sun.";
  if (player hasnt general)
    print " You're dying of thirst. You need to get some water.";
  "";
];

!========================================
! Grammar
!========================================
[ isMakeable;
  if (scope_stage == 1)
    rfalse;!Don't allow multiple objects
  if (scope_stage == 2)
  {
    PlaceInScope(smoke_signals);
    rfalse;
  }
  if (scope_stage == 3)
    "You don't know how to make that.";
];

Extend 'blow'
  * 'on'/'onto' noun -> Blow
  * 'out' noun -> Extinguish
  * noun 'out' -> Extinguish;

Extend 'cut' first
  * noun 'with' held -> Cut;

Extend 'drink' 
  * 'from' held -> Drink;

Extend 'fill' first
  * noun 'with' noun -> FillWith;

Extend only 'kill' replace
  * noun -> Kill
  * noun 'with' held -> Kill;

Extend 'lock' first
  * noun -> Lock;

Extend 'look'
  * 'into' noun -> Search
  * 'out' noun -> Examine
  * 'through' noun -> Examine
  * 'behind'/'under' noun -> LookUnder;

Extend only 'put'
  * 'out' noun -> Extinguish
  * noun 'out' -> Extinguish;

Extend 'read' first
  * noun -> Read;

Extend only 'say' first
  * topic -> Say;

Extend only 'speak' replace
  * -> Talk
  * creature -> Talk
  * noun -> Talk
  * 'to'/'with' creature -> Talk
  * 'to'/'with' noun -> Talk
  * 'to'/'with' creature 'about' topic -> Ask
  * 'to'/'with' noun 'about' topic -> Ask;

Extend 'unlock' first
  * noun -> Unlock;

Verb meta 'about' 'info'
  * -> About;

Verb meta 'credits'
  * -> Credits;

Verb 'extinguish' 'douse' 'snuff' 'unlight'
  * noun -> Extinguish;

Verb 'fire'
  * held -> Fire
  * held 'at' noun -> Shoot reverse
  * 'at' noun 'with' held -> Shoot;

Verb meta 'help' 'instructions'
  * -> Help;

Verb 'hint' 'clue'
  * -> Hint;

Verb 'inspect' = 'examine';

Verb 'make' 'send'
  * scope=isMakeable -> Make
  * scope=isMakeable 'with' held -> Make;

Verb 'dismount'
  * -> Exit
  * creature -> Exit;

Verb 'mount' 'ride'
  * -> Mount
  * creature -> Mount;

Verb 'revive'
  * creature -> Revive;

Verb 'shoot'
  * -> Shoot
  * noun -> Shoot
  * noun 'with' held -> Shoot
  * 'at' noun -> Shoot
  * 'at' noun 'with' held -> Shoot
  * held 'at' noun -> Shoot reverse
  * 'through' noun -> Shoot;

Verb 'talk' 'babble' 'chat' 'communicate' 'converse' 'gab' 'gossip'
  * -> Talk
  * creature -> Talk
  * noun -> Talk
  * 'to'/'with' creature -> Talk
  * 'to'/'with' noun -> Talk
  * 'to'/'with' creature 'about' topic -> Ask
  * 'to'/'with' noun 'about' topic -> Ask;

Verb 'untie' 'disconnect' 'detach' 'unfasten'
  * -> Untie
  * noun -> Untie
  * noun 'from' noun -> Untie;

Verb 'use'
  * noun -> Use;

Verb 'xyzzy' 'plover' 'plugh' 'yoho'
  * -> MagicWord;

!========================================
! Actions
!========================================
[ AboutSub;
  print "This game is an enhanced, text-only port of the semi-graphic Italian adventure 'Kenneth Johnson: Tin Star' by Bonaventura Di Bello. It was originally written with The Quill and Illustrator and published by Edizioni Hobby S.r.l. on the cover tape of 'Viking', no. 5, May 1987 (for ZX Spectrum and C64).^^The data was extracted from the C64 version using UnQuill, translated to English and rewritten for a modern audience with the original author's permission. The coding was done using Inform 6 and the PunyInform library.^^";
  <<Credits>>;
];

[ CreditsSub;
  "Original story and map by Gentili Gian Paolo.^Adaptation and programming by Bonaventura Di Bello.^Technical support by Max Di Bello.^Translation to English by Garry Francis & Google Translate.^Game redesign and coding by Garry Francis & Gianluca Girelli.^Play testing by Garry Francis, Piergiorgio D'Errico, Jade, improvmonster, Robert Eggleston, and RJ Kowalski.";
];

[ ExtinguishSub;
  if (ObjectIsUntouchable(noun))
    return;
  "You can't extinguish ", (ThatOrThose)noun, ".";
];

[ FillWithSub;
  "You can't fill ", (the)noun, " with ", (ThatOrThose)second, ".";
];

[ FireSub;
  if (noun == nothing)
    "You'll have to tell me what to fire.";
  if (ObjectIsUntouchable(noun))
    return;
  "You'll have to tell me what to fire at.";
];

!Delete GoSub if diagonal directions are used
[ GoSub _prop;
  if (selected_direction == ne_to or nw_to or se_to or sw_to)
    "There are no diagonal directions in this game.";
  _prop = selected_direction;
#Iftrue RUNTIME_ERRORS > RTE_MINIMUM;
  if (_prop == 0)
    return _RunTimeError(ERR_INVALID_DIR_PROP);
#Endif;
  return GoDir(_prop);
];

[ HelpSub;
  print "Tell me what to do using simple commands starting with a verb.^^Use LOOK (or L) to refresh the location description. Identify all the objects in the description and EXAMINE (or X) each one. Read responses carefully for hints.^^Use compass directions (N, S, E, W, U and D) to move around. Draw a map as you go.^^Use GET or TAKE to take objects and DROP to drop them again. Use WEAR to wear things like clothing and REMOVE to remove anything that's currently worn. Use INVENTORY (or I) to see what you're carrying and wearing.^^Use AGAIN (or G) to repeat the last command.^^";
#Ifv5;
  print "Use UNDO to undo the last command if you make a mistake.^^";
#Endif;
  "Use SAVE to save the game and RESTORE to restore it again.^^There are over 100 verbs that you can use, so if something doesn't work, try a different verb or a different way of doing things. Use HINT if you get stuck.^^For full instructions, see the game page at <https://bdb-project.itch.io/tin-star>.";
];

[ HintSub;
  "When stuck in a maze, drop unnecessary objects to make that location unique; it'll be easier to map the maze. Examine the location carefully. You can also try to listen, in case you hear something useful.^^Groups of Apaches patrol the area and can prevent your free movement. Talk to NPCs to learn how to get rid of those patrols.";
];

[ LockSub k;
  if (ObjectIsUntouchable(noun))
    return;
  if (noun hasnt lockable)
  {
    PrintMsg(MSG_LOCK_NOT_A_LOCK, 'lock');
    rtrue;
  }
  if (noun has locked)
  {
    PrintMsg(MSG_LOCK_ALREADY_LOCKED);
    rtrue;
  }
  if (noun has open)
  {
    PrintMsg(MSG_LOCK_CLOSE_FIRST);
    rtrue;
  }
  k = RunRoutines(noun, with_key);
  if (k == nothing)
    "You can't see how to lock ", (ItOrThem)noun, ".";
  if (second == nothing && k ~= nothing && k in player)
  {
    second = k;
    print "(with ", (the)second, ")^";
  }
  if (second == nothing)
    "You don't have the key.";
  if (second ~= k)
  {
    PrintMsg(MSG_LOCK_KEY_DOESNT_FIT);
    rtrue;
  }
  give noun locked;
  run_after_routines_msg = MSG_LOCK_DEFAULT;
  run_after_routines_arg_1 = 'lock';
];

[ ShootSub;
  if (noun == nothing)
    "You point your finger in the air and say, ~Bang!~";
  "You can't just go around shooting things arbitrarily, especially in the Wild West. Choose your target carefully or it might get you killed.";
];

[ KillSub;
  "You need to be more specific. Try a verb like ~shoot~.";
];

[ LookUnderSub;
  if (location == thedark)
    "But it's dark.";
  "You find nothing of interest.";
];

[ MakeSub;
  "You don't have the materials required to make ", (ThatOrThose)noun, ".";
];

[ MagicWordSub;
  "If you're expecting a funny response to a magic word, think again.";
];

[ MountSub;
  if (noun == nothing && horse in location)
    noun = horse;
  if (noun == nothing)
    "You need to be more specific.";
  if (ObjectIsUntouchable(noun))
    return;
  <<Enter noun>>;
];

[ ReadSub;
  if (ObjectIsUntouchable(noun, true))
    "I suppose you read tea leaves, too";
  "There's nothing legible on ", (ThatOrThose)noun, ".";
];

[ SaySub i;
  if (consult_words == 0)
    "You have nothing to say.";
  print "~";
  i = consult_from;
  print (firstConsultWord)i++;
  while (i < consult_from + consult_words)
    print " ", (consultWord)i++;
  print ".~^^";
  wn = consult_from;
  if (consult_words == 1 && NextWord() == 'xyzzy' or 'plover' or 'plugh' or 'yoho')
    <<MagicWord>>;
  if (AfterRoutines())
    return;
  "Nothing happens.";
];

[ TalkSub;
  if (noun == nothing)
    "You start talking to no one in particular.";
  if (noun == player)
    "You start talking to yourself, but it's a one-sided conversation.";
  if (RunLife(noun, ##Talk))
    rtrue;
  print_ret (The)noun, " ", (IsOrAre)noun, " not very talkative.";
];

[ UnlockSub k;
  if (ObjectIsUntouchable(noun))
    return;
  if (noun hasnt lockable)
  {
    PrintMsg(MSG_UNLOCK_NOT_A_LOCK, 'unlock');
    rtrue;
  }
  if (noun hasnt locked)
  {
    PrintMsg(MSG_UNLOCK_ALREADY_UNLOCKED, 'unlock');
    rtrue;
  }
  k = RunRoutines(noun, with_key);
  if (k == nothing)
    "You can't see how to unlock ", (ItOrThem)noun, ".";
  if (second == nothing && k ~= nothing && k in player)
  {
    second = k;
    print "(with ", (the)second, ")^";
  }
  if (second == nothing)
    "You don't have the key.";
  if (second ~= k)
  {
    PrintMsg(MSG_UNLOCK_KEY_DOESNT_FIT);
    rtrue;
  }
  give noun ~locked;
  run_after_routines_msg = MSG_UNLOCK_DEFAULT;
  run_after_routines_arg_1 = 'unlock';
];

[ UntieSub;
  if (noun == nothing)
    "What do you want to untie?";
  if (ObjectIsUntouchable(noun))
    return;
  "You can't untie ", (ThatOrThose)noun, ".";
];

[ UseSub;
  if (ObjectIsUntouchable(noun))
    return;
  "You'll have to be more explicit than that.";
];

[ ReviveSub;
  "There is no one to revive, here.";
];

End;
