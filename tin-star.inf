has horsey light;

!========================================
! Room 10: Desert
!========================================
Object room10 "Desert"
with
  description DESERT_DESCRIPTION,
  n_to room09,
  s_to room11,
  e_to room10,
  w_to room11,
  before
  [;
    Hint:
      if (dynamite in nothing)
        "Examine the wagon and do what it suggests.";
      if (dynamite hasnt moved)
        "Don't forget the dynamite.";
  ],
has horsey light;

!----------------------------------------
! Overturned wagon
!----------------------------------------
Object "overturned wagon" room10
with
  article "an",
  name 'overturned' 'wagon',
  description
    [;
      print "This wagon was possibly used for transporting goods across the desert. ";
      if (dynamite in nothing)
        "It might be worth searching it.";
      else
        "You've already searched it, so it's not worth searching it again.";
    ],
    before
    [;
      Search:
        print "You search the wagon";
        if (dynamite in nothing)
        {
          move dynamite to room10;
         " and find a stick of dynamite.";
        }
        ", but don't find anything else of interest.";
    ],
has static;

!----------------------------------------
! Stick of dynamite
!----------------------------------------
Object dynamite "stick of dynamite"
with
  name 'stick' 'of' 'dynamite',
  description "It's a red stick of dynamite with a long fuse.",
  before
  [;
    Burn:
      if (self has light)
        "It's already lit.";
      if (second == nothing && torch in player)
      {
        print "(with the torch)^";
        second = torch;
      }
      if (second == nothing)
        "You'll have to tell me what to light it with.";
      if (second ~= torch or fire or makeshift_fire or coals or campfire)
        "You can't light the dynamite with ", (ThatOrThose)second, ".";
      if (self in player)
        "Are you crazy? You'd better drop the dynamite before lighting it unless you want to meet your maker.";
      if (location ~= room26)
        "You only have one stick of dynamite and you can't see anything worth blowing up around here. I think you should save it until you need it.";
      if (self notin small_hole)
        "If you're trying to blow up the entrance of the mine, the dynamite would be more effective if it was placed in the hole. Have you examined it carefully?";
      give self light;
      StartTimer(self, 3);
      "The wick of the dynamite is now burning like a sparkler. You'd better get out of here before it blows up!";
    Blow, Extinguish:
      if (self hasnt light)
        "It's not lit.";
      "Too late. You can't stop the inevitable.";
    Take:
      if (self has light)
        "Are you crazy? Get out of here before it blows up!";
  ],
  time_out
  [;
    move small_hole to limbo;
    move large_hole to room26;
    move debris to room26;
    if (player notin room26)
      "^KABOOM! You hear an explosion nearby. You can now inspect the damage.";
    deadflag = 1;
    "^KABOOM! The dynamite blows up the rocks that closed the entrance of the mine. It also blows up the stupid sheriff who wasn't smart enough to get out of here, despite being told to do so.";
  ],
  add_to_scope fuse,
  time_left 3,
has;

!----------------------------------------
! Fuse
!----------------------------------------
Object fuse "fuse"
with
  name 'long' 'fuse',
  description "It's a long fuse that's used to light the dynamite. You reckon it would burn for about three moves before the dynamite blows up.",
  before
  [;
    Burn:
      <<Burn dynamite second>>;
  ],
has static;

!========================================
! Room 11: Desert
!========================================
Object room11 "Desert"
with
  description
  [;
    print_ret (string)DESERT_DESCRIPTION, " The desert seems to end to the south, but you can't push your gaze any further, as you're blinded by the sun.";
  ],
  n_to room10,
  s_to room12,
  e_to room10,
  w_to room09,
  before
  [;
    Go:
      if (selected_direction == s_to && player notin horse)
        print_ret (string)YOU_NEED_TO_RIDE_HORSE;
    Hint:
      if (player notin horse)
        print_ret (string)MOUNT_HORSE_BEFORE_GOING, "south.";
  ],
has horsey light;

!========================================
! Room 12: Sierra Sedona
!========================================
Object room12 "Sierra Sedona"
with
  description "The deadly vastness of the desert is to the north. You hope you don't have to return there until you've tracked down the bandits. The vast Sierra Sedona surrounds you for miles in all the other directions, but you know that the bandits would have gone south where the Sierra Sedona continues until it merges with the horizon.",
  n_to room11,
  s_to room13,
  e_to DESTINY_LIES_TO_SOUTH,
  w_to DESTINY_LIES_TO_SOUTH,
  before
  [;
    Go:
      if (selected_direction == n_to && player notin horse)
        print_ret (string)YOU_NEED_TO_RIDE_HORSE;
    Hint:
      if (player notin horse)
        print_ret (string)MOUNT_HORSE_BEFORE_GOING, "north.";
  ],
has horsey light;

!----------------------------------------
! Sierra Sedona (floating object)
!----------------------------------------
Object "Sierra Sedona"
with
  name 'sierra' 'sedona' 'rocky' 'desert' 'red-rock' 'buttes' 'steep' 'canyon' 'walls',
  description "'Sierra' is Spanish for 'mountain range', so this region is the mountains around Sedona. The region is a rocky desert surrounded by red-rock buttes and steep canyon walls. There are plenty of places for bandits to hide, but you're sure they would have headed further south towards Mexico or east towards Pueblo.",
  found_in room12 room13 room14,
has scenery;

!========================================
! Room 13: Sierra Sedona
!========================================
Object room13 "Sierra Sedona"
with
  description "You're crossing the Sierra Sedona, which continues to the north and borders the grassy plain to the east. The foot of the mountain range is to the west and a wisp of smoke can be seen to the south.",
  n_to room12,
  s_to room18,
  e_to room19,
  w_to room14,
  before
  [;
    Hint:
      if (branch hasnt moved)
        "That branch may come in handy.";
  ],
has horsey light;

!----------------------------------------
! Grassy plain (floating object)
!----------------------------------------
Object "grassy plain"
with
  name 'green' 'grass' 'grassy' 'plains' 'broad' 'expanse' 'of' 'flatland' 'prairie' 'steppe' 'grassland',
  description "The grassy plain is a broad expanse of flatland located to the east of the Sierra Sedona. Most of it is covered in prairie, steppe and grasslands, making it ideal hunting ground for the local Indians.",
  found_in room13 room19 room20 room21,
has scenery;

!----------------------------------------
! Mountain range (floating object)
!----------------------------------------
Object "mountain range"
with
  name 'foot' 'of' 'mountain' 'range' 'mountains' 'steep' 'walls',
  description "The steep walls of the mountains are to the west.",
  found_in room13 room14 room15 room17 room18,
has scenery;

!----------------------------------------
! Dead tree
!----------------------------------------
Object tree "dead tree" room13
with
  name 'spooky-looking' 'dead' 'tree',
  description
  [;
    print "It's a spooky-looking dead tree. ";
    if (branch in self)
      "A large branch is hanging from it. It's almost completely detached.";
    else
      "Now that you've taken the dead branch, it looks even spookier.";
  ],
  before
  [;
    Receive:
      "Don't leave things in the tree.";
  ],
has static supporter;

!----------------------------------------
! Large branch
!----------------------------------------
Object branch "large branch" tree
with
  name 'large' 'dry' 'branch',
  description
  [;
    print "It's a large dry branch.";
    if (self has general)
      print " It's burnt on the end from where you were using it as a torch.";
    "";
  ],
  before
  [;
    Burn:
      if (fire in location || makeshift_fire in location || coals in location)
      {
        if (player in horse)
          "You can't reach the fire while you're sitting on your horse.";
        move torch to parent(self);
        give self general;
        remove self;
        "You light up the branch, making a crude lit torch.";
      }
  ],
has;

!----------------------------------------
! Torch
!----------------------------------------
Object torch "torch"
with
  name 'crude' 'lit' 'torch' 'dull' 'yellow' 'flame',
  description "It's a crude torch that burns with a dull yellow flame. It looks like it should last for a while.",
  before
  [;
    Drop:
      if (location == room30)
      {
        move self to limbo;
        move branch to real_location;
        "The torch sizzles when it falls into the puddles of muddy water and your only light source is extinguished.";
      }
    Extinguish:
      move branch to parent(self);
      move self to limbo;
      "You blow out the torch so that it reverts back to a large branch.";
  ],
has light;

!========================================
! Room 14: Foot of Mountain Range
!========================================
Object room14 "Foot of Mountain Range"
with
  description "This is the foot of a long mountain range that marks the western border of the Sedona region. You can follow it to the south or go back to the Sierra Sedona to the east.",
  s_to room15,
  e_to room13,
has horsey light;

!========================================
! Room 15: Edge of Crevasse
!========================================
Object room15 "Edge of Crevasse"
with
  description "A deep crevasse to the south prevents further travel in that direction, although a steep path leads down to the bottom. You can see a sunny expanse of sandy terrain to the east or you can follow the mountain range back to the north.",
  n_to room14,
  e_to room17,
  d_to room16,
  before
  [;
    Hint:
      if (room16 hasnt visited && (player in horse || end_of_rope in player))
        "Leave your horse here so that you can descend into the crevasse. He won't run away.";
      if (room16 hasnt visited)
        "What's at the bottom of the crevasse?";
  ],
has horsey light;

!----------------------------------------
! Deep crevasse (floating object)
!----------------------------------------
Object "deep crevasse"
with
  name 'side' 'edge' 'of' 'deep' 'natural' 'crevasse' 'bottom',
  description "The deep crevasse is very rocky with a steep path down its side.",
  found_in room15 room16,
has scenery;

!----------------------------------------
! Steep path (floating object)
!----------------------------------------
Object "steep path"
with
  name 'steep' 'path',
  description
  [;
    print "The steep path leads ";
    if (self in room15)
      "down to the bottom of the crevasse. You should be able to climb down, but it's too steep for your horse.";
    else
      "up to the top of the crevasse.";
  ],
  found_in room15 room16,
has scenery;

!========================================
! Room 16: Bottom of Crevasse
!========================================
Object room16 "Bottom of Crevasse"
with
  description "The bottom of the crevasse is littered with rocks and debris. Some places host a few stunted tufts of grass, but the water course is dry. The only way out is the steep path up.",
  u_to room15,
  before
  [;
    Hint:
      if (headdress hasnt moved)
        "That headdress may come in handy.";
  ],
has light;

!----------------------------------------
! Rocks
!----------------------------------------
Object "rocks" room16
with
  name 'broken' 'rock' 'rocks' 'stone' 'stones' 'debris',
  description "This harsh landscape is littered with broken rocks. These ones are nothing special.",
has scenery;

!----------------------------------------
! Grass
!----------------------------------------
Object "grass" room16
with
  name 'stunted' 'tufts' 'of' 'grass',
  description "The grass is dry and brittle due to lack of rain. It's a miracle that they can survive at all.",
has scenery;

!----------------------------------------
! Navajo headdress
!----------------------------------------
Object headdress "Navajo headdress" room16
with
  name 'navajo' 'headdress' 'war' 'bonnet',
  description
  [;
    print "This eagle-feather headdress, also called a war bonnet, is traditionally a symbol of power and authority reserved for highly respected Native American men.";
    if (self notin indian)
      print " It surely belongs to a chief.";
    "";
  ],
  before
  [;
    Wear:
      "You could wear it, but that would be disrespectful to the Navajo. They recognise the headdress as a symbol of authority in their culture, just as the tin star is a symbol of authority in yours.";
  ],
has clothing;

!========================================
! Room 17: Sandy Terrain
!========================================
Object room17 "Sandy Terrain"
with
  description "You're on a patch of arid, sandy, almost desert-like terrain. Tumbleweeds occassionally roll past in the wind, sometimes getting stuck in piles of branches or at the foot of the mountains further to the west.",
  w_to room15,
  before
  [;
    Hint:
      if (ties has scenery)
      {
        print "Free the man from his bonds, but you'll need something sharp.";
        if (knife notin nothing)
          print " You've found what you need.";
        "";
      }
      if (man hasnt general)
      {
        print "Try reviving the man";
        if (water notin canteen)
          print ", but you'll need some water";
        ".";
      }
      if (branches hasnt moved)
        "Those dead branches may come in handy.";
      "Make sure you ask the man about anything you're seeking or anything he mentions that sounds important.";
  ],
has horsey light;

!----------------------------------------
! Sandy terrain
!----------------------------------------
Object "sandy terrain" room17
with
  name 'patch' 'of' 'arid' 'sandy' 'desert-like' 'terrain',
  description "This small patch of sandy terrain is not unlike the desert you travelled through earlier in the day.",
has scenery;

!----------------------------------------
! Dead branches
!----------------------------------------
Object branches "dead branches" room17
with
  name 'dead' 'branches',
  description "These dead branches could come in handy if you need to make a fire.",
  before
  [;
    Burn:
      if (location ~= room22)
        "You'd better save those branches for later.";
      if (second == nothing && torch in player)
      {
        print "(with the torch)^";
        second = torch;
      }
      if (second == nothing)
        "You need an open flame to light the branches.";
      if (second ~= torch)
        "You can't burn the branches with ", (ThatOrThose)second, ".";
      if (self in player)
        "Maybe you should drop the branches, first. You don't want to turn into a torch yourself.";
      move self to limbo;
      move makeshift_fire to location;
      "You light the dead branches with your torch, making a fire that burns with a crackling sound and produces a lot of smoke.";
  ],
has pluralname;

!----------------------------------------
! Man tied to stake
!----------------------------------------
Object man "man" room17
with
  name 'man',
  short_name
  [;
    print "man";
    if (ties has scenery)
      print " tied to a stake";
    rtrue;
  ],
  description
  [;
    print "This man looks like yet another victim of those criminals";
    if (ties has scenery)
      ". You can see that he's tied firmly to the stake by some leather ties around his hands and feet.";
    if (self has general)
      ", but he's doing much better now that you've revived him.";
    else
      ". He's unconscious, but at least he's free of his bonds.";
  ],
  life
  [;
    if (ties has scenery)
      "Perhaps it would be better to free the poor man, first.";
    if (action == ##WakeOther)
      <<Revive self>>;
    if (self hasnt general)
      "He's unconscious. How about reviving him first?";
    Ask:
      wn = consult_from;
      switch (NextWord())
      {
        'apaches', 'mescalero':
          "~The Mescalero Apaches can usually be found in the lands around the plateau over there.~ He points to the plateau that is silhouetted against the horizon to the east. ~But stay away from them. They're a great danger. They use smoke signals to communicate that everything is fine, so if you see smoke signals, you'll know the Apaches are there.~";
        'bandits', 'criminals', 'outlaws':
          "~The men you're looking for are possibly the same men who did this to me. I heard them saying their hideout is farther to the east beyond the grassy plain. They insulted me in English, but they spoke in Spanish to each other.~";
        'enemy', 'enemies', 'intruder', 'intruders':
          "~If you're an Apache, then the intruders are the Navajo. If you're a Navajo, then the intruders are the Apaches. And if you're a white man, then you're an enemy of both, so be careful when dealing with the Indians.~";
        'him', 'himself', 'man':
          "~I was heading to the old gold mine to do a bit of prospecting, but it's been blocked by a landslide, so I was heading back home when those bandits attacked me. When they found that I didn't have any gold, they tied me to a stake to get eaten by coyotes. It's a good thing that you came along before the coyotes.~";
        'indian', 'indians':
          "~There are two groups of Indians in this area. The Navajo are mostly on this side of the grassy plain and the Mescalero Apaches are mostly on the other side, to the east. Both groups hunt on the grassy plain and that's where conflicts usually start.~";
        'me', 'myself', 'self':
          "~I know that you saved me and I can see that you're a lawman, as you wear the tin star. Other than that, I don't know you very well at all.~";
        'navajo':
          "~The Navajo are a peaceful people and I've found them to be quite friendly. However, their traditional enemies are the Apache and bands of both peoples can be found in this area, so be careful who you befriend.~";
        'smoke', 'signal', 'signals':
          "~A band of Apaches will usually send smoke signals to indicate that the area is free of intruders, so the other bands will know to search elsewhere.~";
        default:
          "~I don't know anything about that.~";
      }
    Attack:
      "Don't be silly. What has the man done to hurt you?";
    Talk:
      "~I will forever be grateful to you for saving me. If I can help you in any way, just ask me about something.~";
    WakeOther:
      "He's awake now that you've freed and revived him.";
  ],
  before
  [;
    Revive:
      if (self has general)
        "He's doing fine, now. There's no need to revive him again.";
      if (ties has scenery)
        "You should free him from those ties first.";
      if (canteen notin player || water notin canteen)
        "You need some water to revive him.";
      give self general;
      move rifle to player;
      remove water;
      "You move the man out of the direct sunlight, then help him to drink the water out of the canteen until the canteen is empty. After a few minutes, he's regained his senses. He squints at you in the sunlight and smiles. Your gesture has clearly earned you his eternal gratitude.^^~Thank you, my friend. I do not know how to repay you. Ah! I see that you're unarmed.~ He disappears behind the rocks and reappears with a rifle. At first, you think he's going to shoot you, but he gives you the rifle.^^~I'd hidden this before being attacked by a group of bandits. I see from your tin star that you're a sheriff. If you can find those bandits, this rifle may come in handy. Before the bandits surprised me, I noticed some smoke signals from Mescalero Apaches above the plateau to the east. The bandits headed that way. Be careful and good luck, my friend.~";
  ],
has animate;

!----------------------------------------
! Stake
!----------------------------------------
Object stake "stake" room17
with
  name 'stake',
  description
  [;
    print "The stake is firmly buried into the ground. The man ";
    if (self has scenery)
      "is bound to it by leather ties.";
    else
      "was bound to it until you set him free.";
  ],
has scenery;

!----------------------------------------
! Ties
!----------------------------------------
Object ties "leather ties" room17
with
  name 'leather' 'ties' 'bonds',
  description
  [;
    if (self has scenery)
      "Those bandits used wet leather ties to tie this man to the stake. As the leather dries, the ties get shorter and cut into his flesh.";
    else
      "They're the leather ties that the bandits used to tie the man to the stake.";
  ],
  before
  [;
    Cut:
      if (self hasnt scenery)
        "You've already cut them.";
      if (second == nothing && knife in player)
      {
        print "(with the knife)^";
        second = knife;
      }
      if (second == nothing)
        "You'll have to tell me what to cut them with.";
      if (second ~= knife)
        "You'll need something sharper than ", (a)second, ".";
      give ties ~scenery;
      give stake ~scenery static;
      "You cut the leather ties with the knife and they fall to the ground. The man is barely alive, but you'd better revive him, before it's too late.";
    Untie:
      if (self has scenery)
        "After shrinking in the hot sun, they're too tight to untie.";
      else
        "You've already cut them, so there's no need to untie them.";

  ],
has pluralname scenery;

!----------------------------------------
! Winchester rifle
!----------------------------------------
Object rifle "Winchester rifle"
with
  name 'loaded' 'winchester' 'rifle',
  description "It's a loaded Winchester rifle. This is exactly what you need to shoot a target from a safe distance.",
has;

!========================================
! Room 18: In Front of Teepee
!========================================
Object room18 "In Front of Teepee"
with
  description "You find yourself in a barren pocket of land that is sheltered by the mountains to the west. A light breeze stirs the sparse tufts of grass that cover the area. The exit from here is to the north.",
  n_to room13,
  before
  [;
    Hint:
      if (headdress notin indian)
        "The old Indian looks like he could be a chief, except that he's not wearing a war bonnet.";
      if (branch in player)
        "This would be a good place to light the branch.";
      "Make sure you ask the old Indian about anything you're seeking or anything he mentions that sounds important.";
    Listen:
      "You hear the crackling of the burning fire.";
  ],
has horsey light;

!----------------------------------------
! Barren pocket of land
!----------------------------------------
Object "barren pocket of land" room18
with
  name 'barren' 'pocket' 'of' 'land' 'area',
  description "The old Indian has no doubt chosen this pocket of land because of its seclusion.",
has scenery;

!----------------------------------------
! Tufts of grass
!----------------------------------------
Object "tufts of grass" room18
with
  name 'sparse' 'tufts' 'grass',
  description "The tufts of grass stir gently in the breeze.",
has scenery;

!----------------------------------------
! Teepee
!----------------------------------------
Object "teepee" room18
with
  name 'teepee' 'tepee' 'tipi' 'conical' 'tent' 'smoke' 'flaps' 'animal' 'skins' 'framework' 'of' 'wooden' 'poles' 'flap' 'doorway',
  description "The tepee is a conical tent with smoke flaps at the top. It's made of animal skins sewn together and stretched over a framework of wooden poles. It's actually quite a marvel of human engineering. The flap over the doorway faces to the east so that it catches the morning sun.",
  before
  [;
    Enter:
      "You know not to enter a teepee without being invited. As you haven't been invited, you decide to stay outside.";
  ],
has static;

!----------------------------------------
! Small fire (floating object)
!----------------------------------------
Object fire "small fire"
with
  name 'small' 'fire' 'smoke',
  description
  [;
    print "The small fire burns with a crackling sound. ";
    if (self in room18)
      "It warms you up and gives you hope. For a brief moment, you wished this was all a dream, but you have to find those bandits.";
    else
      "This looks like a sign that the bandits camped here, as the Indians would not be careless enough to leave a burning fire unattended.";
  ],
  before
  [;
    Take:
      "Any attempt to carry off a fire would result in terrible burns, so you decide against it.";
  ],
  found_in room18 room34,
has static;

!----------------------------------------
! Old Indian
!----------------------------------------
Object indian "old Indian" room18
with
  article "an",
  name 'old' 'indian' 'chief' 'man',
    description
    [;
      print "The old man warms himself in front of the fire while singing the ancient songs of his people. He looks like someone who has stood beside his warriors in countless battles.";
      if (headdress in self)
        print " He's now wearing the headdress that you gve him.";
      "";
  ],
  life
  [;
    Ask:
      wn = consult_from;
      switch (NextWord())
      {
        'apache', 'apaches', 'mescalero':
          "~They are great danger. They are enemy of Navajo people. Stay away from them. They can be seen near plateau. They use smoke signals to let other Apaches know that everything is fine.~";
        'bandit', 'bandits', 'criminal', 'criminals', 'outlaw', 'outlaws':
          "~This place full of bad people. Bad people you seek may be hiding further east, beyond grassy plain. Beware of them.~";
        'chief', 'him', 'himself':
          "~Me chief. Too old to fight Apache any more, but still chief.~";
        'headdress', 'war', 'bonnet':
          if (headdress notin self)
            "~I lost it. Don't know where. Memory not so good any more.~";
          else
            "He points to the headdress that he's now wearing on his head. ~You found it. You good white man. Thank you.~";
        'knife':
          if (knife in nothing)
            "~What white man want with knife?~";
          else
            "~Me give you knife. You keep it. That gift for returning war bonnet.~";
        'me', 'myself', 'self':
          "~Don't you know you? I don't know you.~";
        'navajo':
          "The old man points to himself. ~Me Navajo.~";
        'smoke', 'signal', 'signals':
          "~Mescalero Apaches send smoke signals to indicate area free of intruders. Others then know to move on and search somewhere else.~";
        default:
          "~I know nothing about that.~";
      }
    Attack:
      "Don't be silly. You don't want to invite the wrath of the Navajo by killing one of their elders.";
    Give:
      if (noun == headdress)
      {
        move headdress to self;
        move knife to player;
        "The old Indian is happy that you've returned his headdress and places it on his head. At least you think he's happy, as his wrinkled old face hides his emotions. ~Thank you white man.~ He takes a knife from a fold in his clothing and offers it to you. You gratefully accept it.";
      }
    Show:
      if (noun == headdress)
        "~Ah, you found headdress. I lost it somewhere. Couldn't find it.~ He puts his arms out, as though he's expecting you to give it to him.";
    Talk:
      "The old man looks at you with a puzzled face. He probably doesn't speak English very well. Try asking him about something more specific.";
  ],
  before
  [;
    Cut, Shoot:
      <<Attack self>>;
  ],
has animate transparent;

!----------------------------------------
! Navajo knife
!----------------------------------------
Object knife "Navajo knife"
with
  name 'Navajo' 'knife',
  description "It's a big, sharp Navajo knife used for skinning bison.",
has;

!========================================
! Room 19: Grassy Plain
!========================================
Object room19 "Grassy Plain"
with
  description "You're on a grassy plain where herds of bison find food and shelter, but there's no bison here at the moment. The grassy plain continues a vast distance to the south and gives way to the Sierra Sedona to the west.",
  s_to room20,
  w_to room13,
  before
  [;
    Go:
      if (selected_direction == s_to && player notin horse)
        print_ret (string)YOU_NEED_TO_RIDE_HORSE;
    Hint:
      if (player notin horse)
        print_ret (string)MOUNT_HORSE_BEFORE_GOING, "south.";
  ],
has horsey light;

!========================================
! Room 20: Grassy Plain
!========================================
Object room20 "Grassy Plain"
with
  description "The green expanse of grass sways like a sea of jade in the light breeze blowing from the south. Scanning the landscape in that direction, you see a plateau. The grassy plain continues a long way to the north.",
  n_to room19,
  s_to room21,
  before
  [;
    Go:
      if (selected_direction == n_to && player notin horse)
        print_ret (string)YOU_NEED_TO_RIDE_HORSE;
    Hint:
      if (player notin horse)
        print_ret (string)MOUNT_HORSE_BEFORE_GOING, "north.";
  ],
has horsey light;

!========================================
! Room 21: Rocky Path
!========================================
Object room21 "Rocky Path"
with
  description "A steep, rocky path marks the end of the grassy plain that extends to the north. The path winds its way up to a vast plateau.",
  n_to room20,
  u_to room22,!Conditional, see below to allow for horse
  before
  [;
    Go:
      if (selected_direction == u_to && rattlesnake hasnt general)
        "There's a rattlesnake blocking the path and the path is too narrow to find a way around it.";
    Hint:
      if (rattlesnake hasnt general)
      {
        print "You need to get past that rattlesnake, but you'll need a weapon to dispatch it.";
        if (rifle notin nothing)
          print " You've found what you need.";
        "";
      }
  ],
has horsey light;

!----------------------------------------
! Rocky path (floating object)
!----------------------------------------
Object "rocky path"
with
  name 'rocky' 'path',
  description "The path is very rocky and very narrow, so you can't deviate from the path. However, it's not steep, so your horse can negotiate the path.",
  found_in room21 room22,
has scenery;

!----------------------------------------
! Rattlesnake
!----------------------------------------
Object rattlesnake "rattlesnake" room21
with
  name 'snake' 'rattlesnake' 'rattler',
  short_name
  [;
    if (self has general)
      print "dead ";
    rfalse;
  ],
  description
  [;
    print "Rattlers are pretty common around here. This one ";
    if (self hasnt general)
      "seems determined to prevent you going any further up the path and there's no way around it.";
    else
      "is dead though, so it's no impediment to your progress up the path.";
  ],
  before
  [;
    Shoot:
      if (second == nothing && rifle in player)
      {
        print "(with the rifle)^";
        second = rifle;
      }
      if (second == nothing)
        print_ret (string)YOU_NEED_FIREARM;
      if (second ~= rifle)
        print_ret (string)YOU_CANT_SHOOT_ANYTHING_WITH, (a)second, ".";
      if (self has general)
        "The snake is already dead, so don't waste bullets. You'll need them when you find the bandits.";
      give self general;
      "You take aim with the rifle and pull the trigger. BANG! Nice shot. You now have one dead rattlesnake, so you can proceed up the narrow path without getting bitten.";
    Take:
      if (self hasnt general)
        "Are you crazy? Those things are deadly!";
      else
        "Er, no thanks. Leave it for the vultures.";
  ],
has animate neuter;

!========================================
! Room 22: Vast Plateau
!========================================
Object room22 "Vast Plateau"
with
  description
  [;
    print "You're on the surface of a vast plateau that extends from here to the east. In the distance to the northeast, you can see another plateau, or perhaps an extension of this one. ";
    if (apaches in room25)
    {
      print "You can see movement on that plateau that looks like a band of Indians";
      if (room25 hasnt visited)
        print", probably Apaches. ";
      else
        print ". As you've seen them up close, you know that they're Mescalero Apaches and you need to divert them. ";
    }
    "A rocky path winds its way back down to the grassy plain far below.";
  ],
  e_to room23,
  d_to room21,
  before
  [;
    Hint:
      if (apaches in room25)
      {
        print "You can see Apaches in the distance. Have you asked others about them? ";
        if (makeshift_fire notin self)
        {
          print "This would be a good place to make some smoke signals. ";
          if (branches notin self)
            "Do you have any fuel?";
          else
            "Do you have a flame to light a fire?";
        }
        "Do you have a blanket to make smoke signals?";
      }
  ],
has horsey light;

!----------------------------------------
! Plateau
!----------------------------------------
Object "plateau" room22
with
  name 'surface' 'of' 'vast' 'plateau' 'extension',
  description "This plateau extends to the east. The one in the distance is possibly an extension of this plateau.",
has scenery;

!----------------------------------------
! Makeshift fire
!----------------------------------------
Object makeshift_fire "makeshift fire"
with
  name 'makeshift' 'fire',
  description "It's a makeshift fire that burns with a crackling sound. It's just what you need to make smoke signals.",
has static;

!----------------------------------------
! Smoke
!----------------------------------------
Object smoke "smoke"
with
  article SOME,
  parse_name
  [ nw i;
    nw = NextWord();
    while (nw == 'smoke' or 'signal' or 'signals')
    {
      i++;
      nw = NextWord();
    }
    return i;
  ],
  description
  [;
    print "This is the smoke you used to make the smoke signals and fool the Apaches into moving to a different region.";
    if (room26 hasnt visited)
      print " You should now be able to cross the plateau without being accosted by them.";
    "";
  ],
  before
  [;
    Make:
      if (location ~= room22)
        "You have no reason to send smoke signals from this location.";
      if (self notin nothing)
        "You've already made some smoke signals.";
      if (makeshift_fire in nothing)
        "You need smoke to make smoke signals and you can't have smoke if you don't have a fire.";
      if (second == nothing && blanket in player)
      {
        print "(with the blanket)^";
        second = blanket;
      }
      if (second == nothing)
        "You need something like a blanket to make smoke signals.";
      if (second ~= blanket)
        "You can't make smoke signals with ", (ThatOrThose)second, ". You need something like a blanket.";
      if (blanket notin player)
        "You aren't holding the blanket.";
      give blanket general;
      move smoke to location;
      move apaches to limbo;
      "You lean down and, using the blanket, you partially cover the fire a couple of times to send two distinctive puffs of smoke. This is the standard signal for 'All is well'. Turning your gaze towards the northeast, you see the Apaches riding away. They're gone now, so you can proceed with your quest.";
  ],
has static;

!========================================
! Room 23: South Edge of Chasm
!========================================
Object room23 "South Edge of Chasm"
with
  description "The plateau extends a long way to the west, but is split in two by a deep chasm to the north. At the bottom of the chasm, you can see the rapids of a stream, but the sheer sides of the chasm prevent you climbing down. Fortunately, you won't need to venture down there, as a long rope bridge spans the chasm.",
  n_to room24,
  w_to room22,
  before
  [;
    Hint:
      if (player in horse && room24 hasnt visited)
        "Leave your horse here so that you can cross the bridge. He won't run away.";
  ],
has horsey light;

!----------------------------------------
! Chasm (floating object)
!----------------------------------------
Object "chasm"
with
  name 'edge' 'of' 'wide' 'deep' 'chasm' 'sheer' 'sides',
  description
  [;
    print "The chasm is both wide and deep and the only way across is via the unstable rope bridge";
    if (self in room24)
      print " that you're currently standing on";
    ".";
  ],
  found_in room23 room24 room25,
has scenery;

!----------------------------------------
! Rapids (floating object)
!----------------------------------------
Object "rapids"
with
  name 'rapids' 'of' 'stream' 'bottom',
  description "You can see the rapids far below, but you can't venture down there.",
  found_in room23 room24 room25,
has scenery;

!----------------------------------------
! Rope bridge (floating object)
!----------------------------------------
Object "rope bridge"
with
  name 'long' 'unstable' 'simple' 'rope' 'suspension' 'bridge',
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'long' or 'unstable' or 'simple' or 'rope' or 'suspension' or 'bridge')
    {
      i++;
      if (nw == 'rope' && (TestScope(rope) || TestScope(tied_rope)))
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description "It's a simple suspension bridge that spans the deep chasm from north to south. It's very unstable, so you can't take your horse across it.",
  before
  [;
    Enter:
      if (self in room23)
        <<Go FAKE_N_OBJ>>;
      if (self in room25)
        <<Go FAKE_S_OBJ>>;
      "You're already on the bridge.";
  ],
  found_in room23 room24 room25,
has scenery;

!========================================
! Room 24: Rope Bridge
!========================================
Object room24 "Rope Bridge"
with
  description "You're standing on the unstable rope bridge that spans the chasm. You can feel it swaying from side to side under your weight and you barely manage to keep your balance. At the bottom of the chasm, a stream rushes away to who knows where. When you look down, you feel quite dizzy and grip the rope tighter. You'd best get off the bridge to the north or south before you're overcome by vertigo.",
  n_to room25,
  s_to room23,
has light;

!========================================
! Room 25: Large Plateau
!========================================
Object room25 "Large Plateau"
with
  description
  [;
    print "You're on a large plateau at the northern edge of the chasm. A long rope suspension bridge crosses the chasm to the south and the plateau itself extends to the north. You can see another plateau far to the southwest";
    if (smoke in room22)
      print " and there's smoke coming from that plateau";
    ".";
  ],
  n_to
  [;
    if (apaches in self)
      "A group of Mescalero Apaches are blocking the way and won't let you pass. You need to somehow send them away before you can continue to the north.";
    else
      return room26;
  ],
  s_to room24,
  before
  [;
    Hint:
      if (apaches in self)
        "Those Apaches look mean. You'll have to get rid of them, but you can't do it from here. Have you asked others about the Apaches?";
  ],
has light;

!----------------------------------------
! Plateau
!----------------------------------------
Object "plateau" room25
with
  name 'large' 'plateau',
  description "This plateau extends to the north and another plateau can be seen to the southwest.",
has scenery;

!----------------------------------------
! Mescalero Apaches
!----------------------------------------
Object apaches "Mescalero Apaches" room25
with
  article "a group of",
  name 'group' 'of' 'mescalero' 'apaches' 'indians' 'men',
  description "This is one of the groups of Mescalero Apaches that frequently raid the region. They do not pose a direct threat to you at the moment, unless you do something stupid.",
  life
  [;
    Ask:
      "The Apaches stare at you. If they understand what you're saying, then they certainly don't want to reply.";
    Attack:
      deadflag = 1;
      "You attack the Apaches, but they are too numerous. Your scalp will soon become a warrior's ornament.";
    Talk:
      "~Go away, white man. You're not welcome here.~";
  ],
  before
  [;
    Shoot:
      if (second == nothing && rifle in player)
      {
        print "(with the rifle)^";
        second = rifle;
      }
      if (second == nothing)
        "You would need a firearm to shoot them.";
      if (second ~= rifle)
        "Shooting the Apaches with ", (the)second, " would be just as effective as shooting them with a pop gun, except that you haven't got a pop gun.";
      deadflag = 1;
      "You open fire on the Apaches, but they are too numerous and overwhelm you. Your scalp will soon become a warrior's ornament.";
  ],
has animate pluralname;

!========================================
! Room 26: End of Plateau
!========================================
Object room26 "End of Plateau"
with
  description
  [;
    print "The vast plateau ends here in front of the entrance to an old gold mine. ";
    if (small_hole in self)
      print "However, you can't enter it, as a landslide has blocked the entrance, leaving only a small hole no bigger than a mouse hole. ";
    else
      print "The entrance to the north is now open, thanks to a powerful explosion that blew the bulk of the rocks away. ";
    "The plateau extends to the south for a long stretch.";
  ],
  n_to room27,
  s_to room25,
  in_to room27,
  before
  [;
    Go:
      if (selected_direction == n_to or in_to && small_hole in self)
        "There are rocks blocking the entrance and you can't get in.";
    Hint:
      if (small_hole in self)
      {
        print "A bit of excavation is in order. ";
        if (dynamite in nothing)
          "I hate to disappoint you, but you missed something back in the desert.";
        else
          "You've found what you need. Now's the time to make use of it.";
      }
  ],
has light;

!----------------------------------------
! Plateau
!----------------------------------------
Object "plateau" room26
with
  name 'end' 'of' 'vast' 'plateau',
  description "The end of the plateau does not drop down, but steps up to a higher mountain. The entrance to a mine can be seen in this mountain.",
has scenery;

!----------------------------------------
! Landslide
!----------------------------------------
Object landslide "landslide" room26
with
  name 'landslide' 'rocks',
  description
  [;
    if (small_hole in location)
      "The rocks from the landslide block the entrance to the mine.";
    else
      "The bulk of the rocks have been blown away or turned into rubble.";
  ],
has scenery;

!----------------------------------------
! Entrance to mine
!----------------------------------------
Object "mine" room26
with
  name 'entrance' 'to' 'mine',
  description
  [;
    if (small_hole in location)
      "The entrance to the mine is blocked by a landslide.";
    else
      "The explosion has cleared the landslide, so you can now enter the mine.";
  ],
has scenery;

!----------------------------------------
! Small hole
!----------------------------------------
Object small_hole "small hole" room26
class OpenContainer
with
  name 'small' 'hole' 'soil',
  description
  [;
    print "It's a small hole, about the width of a candle. ";
    <<Search self>>;
  ],
  before
  [;
    Receive:
      if (noun ~= dynamite)
        print_ret (The)noun, " won't fit in the hole.";
  ],
has container open scenery;

!----------------------------------------
! Large hole
!----------------------------------------
Object large_hole "large hole in the mountain wall"
with
  parse_name
  [ i;
    while (NextWord() == 'large' or 'hole' or 'in' or 'the' or 'mountain' or 'wall')
      i++;
    return i;
  ],
  description "Wow. That stick of dynamite sure blew a big hole here.",
  before
  [;
    Enter:
      <<Go FAKE_N_OBJ>>;
  ],
has static;

