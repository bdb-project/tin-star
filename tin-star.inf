Constant Story "Tin Star";
Constant Headline "^Kenneth Johnson trilogy #2^Copyright (c) 2025 Gianluca Girelli and Garry Francis^https://bdb-project.itch.io^Type ABOUT for further info and credits.^^";

Array UUID_ARRAY string "UUID://01f08399-607b-41c2-9878-dddb31a25de0//";
#Ifdef UUID_ARRAY;
#Endif;

Release 2;
!Serial "YYMMDD";

!Inform 6 constants
Constant DEATH_MENTION_UNDO;
Constant MAX_CARRIED = 10;
Constant NO_SCORE;

!PunyInform constants
Constant CUSTOM_ABBREVIATIONS;
Constant OPTIONAL_EXTENDED_METAVERBS;
Constant OPTIONAL_EXTENDED_VERBSET;
Constant OPTIONAL_FULL_DIRECTIONS;
Constant OPTIONAL_PROVIDE_UNDO;
Constant RUNTIME_ERRORS 0;!0 for release, 2 for debug

!PunyInform static messages
Constant MSG_COMMENT_NO_TRANSCRIPT "Comment recorded. Use SCRIPT ON to save future comments in a transcript.^";
Constant MSG_COMMENT_TRANSCRIPT "Comment recorded.^";
Constant MSG_DIG_NO_USE "You have better things to do than dig for buried treasure.";
Constant MSG_PARSER_NO_INPUT "You need to enter a command.";
Constant MSG_PARSER_UNKNOWN_VERB "That's not a verb I recognise.";
Constant MSG_SHOUT_DEFAULT "~Yeehaa!~";
Constant MSG_SING_DEFAULT "~Oh give me a home where the buffalo roam,^Where the deer and the antelope play,^Where seldom is heard a discouraging word,^And the skies are not cloudy all day.~";
Constant MSG_SMELL_DEFAULT "The only thing you can smell is yourself. You haven't had a bath for days.";
Constant MSG_SORRY_DEFAULT "Oh, don't apologise.";
Constant MSG_SWIM_DEFAULT "Swimming requires water. Take a look around. Do you see any water here?";
Constant MSG_THINK_DEFAULT "Think Kenneth, think. There must be a way to track those bandits down.";
Constant MSG_WAIT_DEFAULT "Time passes...";
Constant MSG_WAKE_DEFAULT "You're not asleep.";

!PunyInform dynamic messages
Constant MSG_CLOSE_NOT_OPEN 1000;
Constant MSG_LOCK_ALREADY_LOCKED 1001;
Constant MSG_LOCK_CLOSE_FIRST 1002;
Constant MSG_LOCK_KEY_DOESNT_FIT 1003;
Constant MSG_UNLOCK_ALREADY_UNLOCKED 1004;
Constant MSG_UNLOCK_KEY_DOESNT_FIT 1005;

!Game-specific constants
Constant SOME "some";
Constant YOUR "your";
Constant CANTEEN_IS_EMPTY "The canteen is empty.";
Constant CANYON_PREVENTS_PROGRESS "The huge rock walls of the canyon prevent progress in that direction.";
Constant COALS_ARE_STILL_WARM "The coals are still warm.";
Constant CONSTANT_DRIPPING_COMES_FROM "A constant dripping comes from ";
Constant DESERT_DESCRIPTION "The hot summer sun of the desert reflects on the golden sea of burning sand. The desert extends in every direction, but you can't get your bearings, because the landscape is so similar wherever you turn.";
Constant DESTINY_LIES_TO_SOUTH "Your destiny lies to the south.";
Constant FIRST_OPENING_CANTEEN "(first opening the canteen)^";
Constant LISTEN_OR_DROP_ITEM "Try listening or dropping an item in each tunnel to make it unique.";
Constant MINE_DESCRIPTION "You're lost in an intricate network of mining tunnels. There appears to be tunnels in every direction, but they're quickly swallowed up by the darkness. In the silence of the mine, you hear a constant dripping.";
Constant MOUNT_HORSE_BEFORE_GOING "Mount your horse before going ";
Constant NO_WATER_HERE "There's no water here.";
Constant YOU_CANT_DRINK_FROM "You can't drink from ";
Constant YOU_EMPTY_CANTEEN "You empty the canteen and the water soaks into the ground. That was probably a silly thing to do.";
Constant YOU_NEED_FIREARM "You'd need a firearm if you want to shoot anything.";
Constant YOU_NEED_LIGHT_SOURCE "You'll need a light source to map the tunnels.";
Constant YOU_NEED_TO_RIDE_HORSE "It's a wide open range that way and too far to walk. You'll need to ride your horse.";
Constant YOU_CANT_SHOOT_ANYTHING_WITH "Very funny. You can't shoot anything with ";
Constant YOU_FILL_CANTEEN "You fill the canteen with water.";

!Replaced actions
Replace DrinkSub;
Replace GoSub; !Delete if diagonal directions are used
Replace LockSub;
Replace UnlockSub;

Include "globals.h";

!Game-specific variables
Attribute horsey;

!========================================
! Entry point routines
!========================================
[ InScope person i;
  if (location ~= thedark)
    rfalse;
  if (real_location == room31 && boards in room31)
    PlaceInScope(boards);
  if (person == player)
    objectloop(i in parent(player))
      if (i has moved)
        PlaceInScope(i);
  rfalse;
];

[ GamePreRoutine;
  ! Examine doesn't work in dark locations, but we want it to work in room31
  if (location == thedark && real_location == room31 && boards in room31 && action == ##Examine)
  {
    if (noun provides description)
      PrintOrRun(noun, description);
    else
      PrintMsg(MSG_EXAMINE_NOTHING_SPECIAL);
    rtrue;
  }
  rfalse;
];

[ LookRoutine;
  if (location == thedark && real_location == room31)
    if (boards in room31)
      "^You can see cracks of light to the south. You wouldn't have been able to see them if you had a lit torch with you.";
    else
      "^Sunlight shines in from the entrance to the south.";
];

[ LibraryMessages p_msg p_arg_1 p_arg_2;
  switch (p_msg)
  {
    MSG_CLOSE_NOT_OPEN:
      print_ret (CTheyreOrIts)noun, " already closed.";
    MSG_LOCK_ALREADY_LOCKED:
      print_ret (CTheyreOrIts)noun, " already locked.";
    MSG_LOCK_CLOSE_FIRST:
      "You'll have to close ", (ItOrThem)noun, " first.";
    MSG_LOCK_KEY_DOESNT_FIT:
      print_ret (The)second, " ", (DoesntOrDont)second, " fit the lock.";
    MSG_UNLOCK_ALREADY_UNLOCKED:
      print_ret (CTheyreOrIts)noun, " already unlocked.";
    MSG_UNLOCK_KEY_DOESNT_FIT:
      print_ret (The)second, " ", (DoesntOrDont)second, " fit the lock.";
  }
  p_arg_1 = p_arg_2;
];

Include "puny.h";

!========================================
! Initialisation
!========================================
[ Initialise;
  location = room01;
  lookmode = 2;
  move clothes to player;
  no_implicit_actions = true;
  player.description = PlayerDescription;
  "^In the wild West, the tin star is the symbol of law and order. The men who wear the tin star are respected by the community, as they face violent and cunning criminals nearly every day.^^After a group of criminals kidnapped your wife and daughter and almost took your own life, you decided to join the ranks of these brave lawmen and became a sheriff in the town of Tucson, Arizona. For a few months, your life passed quietly and your duties as sheriff were limited to short missions, like escorting outlaws to prison.^^Then, one day, the tranquility of Tucson was shattered by the arrival of a group of dangerous bandits whose faces had long decorated WANTED posters in many Western Union Telegraph offices. The bank was their target and your absence, due to a disturbance at the nearby silver mines of San Xavier, was their opportunity to strike. They arrived shooting and shouting, spreading fear everywhere, and robbed the bank of the savings of the hard-working people of Tucson. Some citizens and bank employees were even killed by the bandits. The family and friends of the deceased demanded justice.^^When you arrived back in Tucson the following day, you were sickened by the stories you heard about the atrocities carried out by these ruthless bandits. You quickly collected food, water, guns and ammunition, saddled your horse, and set off in pursuit of the bandits. They only had one day's head start, so you should be able to catch them.^^Unfortunately for you, the bandits had anticipated your move and set an ambush in a narrow canyon on the edge of the desert. You were taken by surprise, knocked out, tied up and left to die in the desert sun. When you woke up, you found yourself in the shadow of the canyon. Your horse was nearby, but most of your other belongings, including your guns, were gone. An ordinary man would have slowly died of thirst under the hot summer sun, but you were no ordinary man and you were determined to prove it.^";
];

!========================================
! Classes
!========================================
Class OpenableContainer
with
  invent
  [;
    if (inventory_stage == 2 && (self hasnt open || child(self) == 0))
      rtrue;
  ],
has;

Class OpenContainer
with
  invent
  [;
    if (inventory_stage == 2 && children(self) == 0)
      rtrue;
  ],
has container open;

!========================================
! Inventory
!========================================
!----------------------------------------
! Clothes
!----------------------------------------
Object clothes "clothes"
with
  article YOUR,
  name 'clothes' 'garments' 'shirt',
  description "You're the sheriff of Tucson and dressed accordingly. Most notable is the tin star pinned to your shirt.",
  before
  [;
    Disrobe:
      "You'd better not. You'll need your clothes to protect you from the blazing desert sun.";
  ],
  add_to_scope tin_star,
has clothing pluralname worn;

!----------------------------------------
! Tin star
!----------------------------------------
Object tin_star "tin star"
with
  name 'tin' 'star',
  description "Very early tin stars were hand-made from tin cans, but this one is embossed from sheet brass. It's a five-pointed star with little circles at the tip of each point and 'SHERIFF' embossed across the centre.",
  before
  [;
    Remove, Take:
      "Leave it pinned to your shirt, as it's a sign of your authority in this region.";
  ],
has scenery;

!========================================
! Room 1: Narrow Canyon
!========================================
Object room01 "Narrow Canyon"
with
  description "You're in a narrow canyon that extends from east to west. The huge rock walls of the canyon cast a shadow over this part of the desert. You can see the main expanse of the desert to the west and the road to Tucson to the east.",
  n_to CANYON_PREVENTS_PROGRESS,
  s_to CANYON_PREVENTS_PROGRESS,
  e_to "Right now, you need to chase those bandits. They would have fled to the west.",
  w_to room02,
  u_to "The rock walls of the canyon are far too steep and too high to climb.",
  before
  [;
    Go:
      if (rope has static)
        "You can't go anywhere while you're tied up with that rope.";
    Hint:
      if (rope has static)
      {
        print "The rope can be burned";
        if (coals hasnt light)
          print " if you can rekindle the fire";
        ".";
      }
      if (horse in self && tied_rope notin horse)
        "Try tying the rope to your horse.";
      if (blanket hasnt moved)
        "Don't forget the blanket.";
      if (horse hasnt general)
        "Try leading your horse to water.";
      "Go west young man.";
  ],
has horsey light;

!----------------------------------------
! Canyon
!----------------------------------------
Object "canyon" room01
with
  name 'narrow' 'canyon' 'desert' 'floor' 'sand' 'shadow' 'shade' 'sun' 'sunlight',
  description "The shade of the canyon protects you from the direct sunlight, but it's still very hot.",
has scenery;

!----------------------------------------
! Rock walls
!----------------------------------------
Object "rock walls" room01
with
  name 'huge' 'steep' 'high' 'rock' 'wall' 'walls',
  description "The rock walls of the canyon are very steep and cast a shadow over the desert floor.",
  before
  [;
    Climb:
      <<Go FAKE_U_OBJ>>;
  ],
has pluralname scenery;

!----------------------------------------
! Horse
!----------------------------------------
Object horse "horse" room01
with
  article "your",
  name 'horse' 'stallion',
  description
  [;
    print "He's your faithful stallion";
    if (tied_rope in self)
      print " who currently has a rope tied to him";
    ".";
  ],
  react_before
  [ destination;
    if (player notin self && end_of_rope notin player)
      rfalse;
    if (player in self && noun == nothing)
      rfalse;
    if (player in self && action == ##Examine or ##Answer or ##Ask or ##AskFor or ##Shoot or ##Show or ##Talk or ##Tell)
      rfalse;
    if (player in self && CommonAncestor(player, noun) == location)
    {
      if (noun == branch && branch hasnt moved)
        rfalse;
      "You can't reach ", (the)noun, " while you're sitting on your horse.";
    }
    Drop:
      if (player in self && noun in player && noun hasnt worn)
      {
        move noun to location;
        print (The)noun, " fall";
        if (noun hasnt pluralname)
          print "s";
        " to the ground.";
      }
    Go:
      if (player in self && self hasnt general)
        "Your horse refuses to move. He only does that when he's thirsty, so you'll need to lead him to water.";
      destination = location.(direction_properties_array->selected_direction_index);
      if (destination ofclass Object)
      {
        if (destination has door || destination hasnt horsey)
          "You can't take the horse that way. You'll have to leave him behind.";
        if (player notin self && ((location == room11 && selected_direction == s_to) || (location == room12 && selected_direction == n_to)))
          rfalse;
        if (player notin self && ((location == room19 && selected_direction == s_to) || (location == room20 && selected_direction == n_to)))
          rfalse;
        if (location == room21 && selected_direction == u_to && rattlesnake hasnt general)
          rfalse;
        else
          move self to destination;
      }
  ],
  life
  [;
    Give:
      if (noun == canteen && canteen has open && water in canteen && horse hasnt general)
      {
        remove water;
        "With great difficulty, you try to pour the water into your horse's mouth and he tries to lap it up, but you spill most of it. The canteen is now empty and your horse is still thirsty, so you'll need to lead him to water.";
      }
  ],
  before
  [ destination;
    Drop:
      if (end_of_rope in player)
        <<Drop tied_rope>>;
    Enter:
      if (rope has static)
        "Aren't you still tied up?";
      if (player hasnt general)
         "You're too weak to mount your horse right now. You need to eat something.";
    Go:
      destination = location.(direction_properties_array->selected_direction_index);
      if (destination ofclass Object)
      {
        if (destination has door || destination hasnt horsey)
        {
          print "You can't take the horse that way. You'll have to leave him behind.^";
          return 2;
        }
      }
      return 1;
    Take:
      if (tied_rope in horse && end_of_rope notin player)
        <<Take tied_rope>>;
  ],
  after
  [;
    Enter:
      "You get on your horse.";
    Exit, GetOff:
      "You get off your horse.";
  ],
has animate enterable supporter;

!----------------------------------------
! Rope
!----------------------------------------
Object rope "rope" room01
with
  name 'rope',
  description
  [;
    print "It's a long rope";
    if (self has static)
      print " that ties you up";
    ".";
  ],
  react_before
  [;
    Take:
      if (self has static)
        "You can't take anything while you're tied up.";
  ],
  before
  [;
    Burn:
      if (location ~= room01 || coals in nothing)
        "You don't see a source of heat intense enough to burn the rope.";
      if (self hasnt static)
        "Don't burn any more of it. It might come in useful.";
      give self ~static;
      "You edge closer to the fire and burn the rope just enough to free yourself.";
    Tie:
      if (second == nothing && horse in location)
      {
        print "(to your horse)^";
        second = horse;
      }
      if (second == nothing)
        "You'll have to tell me what to tie it to.";
      if (second ~= horse)
        "You can't tie the rope to ", (the)second, ".";
      if (horse notin location)
        "Your horse is not here.";
      remove self;
      move tied_rope to horse;
      move end_of_rope to player;
      PronounNotice(tied_rope);
      "You tie the rope to your horse and grab the other end. He will now follow you around when you're holding the rope.";
    Untie:
      if (self has static)
        "This may come as a surprise to you, but you can't untie it while you're tied up.";
  ],
has static;

!----------------------------------------
! Tied rope
!----------------------------------------
Object tied_rope "rope tied to your horse"
with
  name 'end' 'of' 'rope' 'tied',
  description
  [;
    print "It's a short rope tied to your horse. As you're ";
    if (end_of_rope notin player)
      print "not ";
    print "holding the end of the rope, your horse will ";
    if (end_of_rope notin player)
      print "not ";
    "follow you.";
  ],
  before
  [;
    Drop:
      if (end_of_rope notin player)
        "You're not holding it.";
      remove end_of_rope;
      "You drop the end of the rope, so that your horse will no longer follow you.";
    Insert:
      "You'll have to untie the rope before you can put it in anything.";
    PutOn:
      "You'll have to untie the rope before you can put it on anything.";
    Take:
      if (end_of_rope in player)
        "You're already holding the rope.";
      move end_of_rope to player;
      "You grab the other end of the rope so that your horse will follow you.";
    Tie:
      "It's already tied to your horse.";
    Untie:
      remove self;
      if (end_of_rope in player)
        remove end_of_rope;
      move rope to player;
      PronounNotice(rope);
      "You untie the rope from your horse, so it will no longer follow you.";
  ],
has scenery;

!----------------------------------------
! End of rope
!----------------------------------------
Object end_of_rope "end of a rope tied to your horse"
with
  article "the",
has;

!----------------------------------------
! Remains of a campfire
!----------------------------------------
Object campfire "remains of a campfire" room01
with
  article "the",
  name 'remains' 'of' 'fire' 'campfire',
  description
  [;
    print "It's the remains of a campfire. ";
    if (coals hasnt light)
      print_ret (string)COALS_ARE_STILL_WARM;
    else
      "There are some hot coals burning in the fire.";
  ],
  before
  [;
    Blow:
      <<Blow coals>>;
    Receive:
      "You'd better not put anything in the campfire or it might get burnt.";
    Take:
      <<Take coals>>;
    Touch:
      <<Touch coals>>;
  ],
has container open static;

!----------------------------------------
! Coals
!----------------------------------------
Object coals "coals" campfire
with
  name 'coals' 'ashes',
  description
  [;
    if (self hasnt light)
      print_ret (string)COALS_ARE_STILL_WARM;
    else
      "When you blew on the coals, a flame sparked into life and it's still burning.";
  ],
  before
  [;
    Blow:
      if (self hasnt light)
      {
        give self light;
        "You blow on the warm coals and a flame suddenly lights up.";
      }
      give self ~light;
      "You blow the flame out. That was pretty silly.";
    Take:
      "The coals in the campfire are too hot to take.";
    Touch:
      "The coals in the campfire are too hot to touch.";
  ],
has pluralname static;

!----------------------------------------
! Old blanket
!----------------------------------------
Object blanket "old blanket" room01
with
  article "an",
  name 'old' 'blanket',
  description
  [;
    print "It's an Indian blanket decorated with beautiful geometric designs. It's useful to shield yourself from the cold desert nights and to make smoke signals, should the need arise.";
    if (self has general)
      print " It now smells like a barbeque.";
    "";
  ],
  before
  [;
    Smell:
      print "The blanket smells ";
      if (self hasnt general)
        "a bit musty.";
      else
        "like a barbeque, since you used it to send smoke signals.";
  ],
has;

!========================================
! Room 2: Desert
!========================================
Object room02 "Desert"
with
  description
  [;
    print_ret (string)DESERT_DESCRIPTION, " To the east, the enormous walls of a canyon mark the edge of the desert and the beginning of the road to Tucson.";
  ],
  n_to room02,
  s_to room02,
  e_to room01,
  w_to room03,
  after
  [;
    Go:
      if (self hasnt visited)
        StartDaemon(self);
  ],
  daemon
  [;
    self.time_left--;
    if (self.time_left == 0)
    {
      deadflag = 1;
      "^Your vision blurs and everything starts to disappear behind a heavy black veil. You lose consciousness and collapse on the burning desert sand, soon to be food for the vultures. The desert is an unforgiving place. You needed to find water before anything else. (Try RESTART instead of UNDO.)";
    }
    if (self.time_left < 3)
      "^You need to drink some water. Now!";
    if (self.time_left < 6)
      "^You're exhausted. If you don't drink some water soon, you'll collapse.";
    if (self.time_left < 11)
      "^The heat is unbearable and your throat is getting dry, too dry.";
  ],
  time_left 20,
has horsey light;

!----------------------------------------
! Desert (floating object)
!----------------------------------------
Object desert "desert"
with
  name 'desert' 'landscape' 'huge' 'expanse' 'of' 'burning' 'hot' 'sand' 'golden' 'sea',
  description "It's a huge expanse of burning hot sand as far as the eye can see.",
  found_in room02 room03 room04 room05 room06 room07 room08 room09 room10 room11,
has scenery;

!========================================
! Room 3: Desert
!========================================
Object room03 "Desert"
with
  description DESERT_DESCRIPTION,
  n_to room06,
  s_to room04,
  e_to room02,
  w_to room05,
has horsey light;

!========================================
! Room 4: Desert
!========================================
Object room04 "Desert"
with
  description DESERT_DESCRIPTION,
  n_to room05,
  s_to room04,
  e_to room03,
  w_to room05,
has horsey light;

!========================================
! Room 5: Desert
!========================================
Object room05 "Desert"
with
  description DESERT_DESCRIPTION,
  n_to room06,
  s_to room04,
  e_to room03,
  w_to room04,
  before
  [;
    Hint:
      if (saddle_bag in nothing)
        "Try examining the carcass.";
      if (saddle_bag hasnt open && (canteen hasnt moved || pemmican hasnt moved))
        "Try opening the saddle bag.";
  ],
has horsey light;

!----------------------------------------
! Carcass of a horse
!----------------------------------------
Object carcass "carcass of a horse" room05
with
  article "the",
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'carcass' or 'of' or 'dead' or 'horse')
    {
      i++;
      if (nw == 'horse' && TestScope(horse))
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description
  [;
    print "It's a dead horse, possibly left here by the owner while trying to cross this deadly place. It's been stripped of its harness, bridle and saddle.";
    if (saddle_bag in nothing)
    {
      move saddle_bag to location;
      print " Only a battered saddle bag has been left beside the carcass.";
    }
    "";
  ],
  before
  [;
    Search:
      <<Examine self>>;
    Smell:
      "It's a dead horse that's been left to rot in the desert sun. Needless to say, it smells pretty bad.";
    Take:
      "No way! Firstly, you're not strong enough to carry it. Secondly, it's pretty smelly.";
  ],
has animate neuter;

!----------------------------------------
! Saddle bag
!----------------------------------------
Object saddle_bag "saddle bag"
with
  name 'saddle' 'bag' 'saddlebag',
  description
  [;
    print "It's an old and battered saddle bag. ";
    <<Search self>>;
  ],
  before
  [;
    Receive:
      if (noun == blanket or branch or branches or rifle or rope or torch)
        print_ret (The)noun, " won't fit in the saddle bag.";
  ],
has container openable;

!----------------------------------------
! Pemmican
!----------------------------------------
Object pemmican "pemmican" saddle_bag
with
  article "some",
  name 'pemmican',
  description "A pressed cake of pounded dried meat mixed to a paste with melted fat and other ingredients. It's a Native American food.",
  before
  [;
    Eat:
      if (bulk_water hasnt general)
        "Your mouth is too dry to eat. You need to drink some water first.";
      give player general;
      move self to limbo;
      "You feel your strength coming back. You should now be able to mount your horse.";
  ],
has edible;

!----------------------------------------
! Canteen
!----------------------------------------
Object canteen "canteen" saddle_bag
class OpenableContainer
with
  name 'tin' 'canteen',
  description
  [;
    print "It's a tin canteen. ";
    <<Search self>>;
  ],
  before
  [;
    Drink:
      "You can drink water or drink from the canteen, but you can't drink the canteen itself. That wouldn't fit down your throat.";
    DrinkFrom:
      if (self hasnt open)
      {
        print (string)FIRST_OPENING_CANTEEN;
        give canteen open;
      }
      if (water notin self)
        print_ret (string)CANTEEN_IS_EMPTY;
      <<Drink water>>;
    Empty:
      if (self hasnt open)
      {
        print (string)FIRST_OPENING_CANTEEN;
        give canteen open;
      }
      if (water notin self)
        print_ret (string)CANTEEN_IS_EMPTY;
      remove water;
      print_ret (string)YOU_EMPTY_CANTEEN;
    Fill:
      if (bulk_water in location)
      {
        print "(with water)^";
        second = bulk_water;
      }
      <<FillWith self second>>;
    FillWith:
      if (self hasnt open)
      {
        print (string)FIRST_OPENING_CANTEEN;
        give canteen open;
      }
      if (water in self)
        "It's already full.";
      if (second == nothing)
        print_ret (string)NO_WATER_HERE;
      if (second ~= bulk_water)
        "You can't fill the canteen with ", (ThatOrThose)second, ".";
      if (second notin location)
        print_ret (string)NO_WATER_HERE;
      move water to self;
      print_ret (string)YOU_FILL_CANTEEN;
    Receive:
      if (noun ~= bulk_water)
        "The only thing you can put in the canteen is water.";
  ],
has container openable;

!----------------------------------------
! Water
!----------------------------------------
Object water "water"
with
  article SOME,
  name 'water',
  description "It's just water. Clean, clear, refreshing water.",
  before
  [;
    Drink:
      if (second ~= nothing && second ~= canteen)
        print_ret (string)YOU_CANT_DRINK_FROM, (ThatOrThose)second, ".";
      if (bulk_water has general)
        "Your thirst is already quenched. Save it for later.";
      give bulk_water general;
      StopDaemon(room02);
      remove self;
      "You drink from the canteen until all the water is gone. After what you've been through in the desert, you feel so refreshed.";
    Empty:
      remove water;
      print_ret (string)YOU_EMPTY_CANTEEN;
    Take:
      "If you want to take the water out of the canteen, just empty it.";
  ],
has;

!========================================
! Room 6: Desert
!========================================
Object room06 "Desert"
with
  description DESERT_DESCRIPTION,
  n_to room07,
  s_to room03,
  e_to room08,
  w_to room05,
has horsey light;

!========================================
! Room 7: Desert
!========================================
Object room07 "Desert"
with
  description DESERT_DESCRIPTION,
  n_to room08,
  s_to room06,
  e_to room08,
  w_to room09,
  before
  [;
    Hint:
      if (bulk_water hasnt general)
        "This looks like a good place to have a drink.";
      if (horse hasnt general)
        "This looks like a good place to water your horse.";
      if (TestScope(canteen) && water notin canteen)
        "This looks like a good place to fill your canteen.";
    Swim:
      "The water isn't deep enough for swimming.";
  ],
  after
  [;
    Go:
      if (horse in self && horse hasnt general)
      {
        <Look>;
        give horse general;
        "^As soon as your horse spots the water, he drinks until his thirst is quenched. You should be able to ride him now.";
      }
  ],
has horsey light;

!----------------------------------------
! Basin of water
!----------------------------------------
Object basin "basin of water" room07
with
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'basin' or 'of' or 'water')
    {
      i++;
      if (nw == 'water' && (TestScope(bulk_water) || (TestScope(water))))
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description "It's a basin of clear water surrounded by tufts of grass. It looks very refreshing in this desert environment.",
  before
  [;
    Drink:
      "You can drink water or drink from the basin, but you can't drink the basin itself, as that's part of the landscape.";
    DrinkFrom:
      <<Drink bulk_water self>>;
  ],
has static;

!----------------------------------------
! Water (floating object)
!----------------------------------------
Object bulk_water "water"
with
  name 'water',
  before
  [;
    Drink:
      if (second ~= nothing && second ~= basin or trough)
        print_ret (string)YOU_CANT_DRINK_FROM, (ThatOrThose)second, ".";
      if (self has general)
        "You don't really need another drink right now, so you just take a sip.";
      give self general;
      StopDaemon(room02);
      "You kneel on the ground and take a deep drink of water. After what you've been through in the desert, you now feel refreshed.";
    Take:
      if (second == nothing && canteen in player)
      {
        print "(with the canteen)^";
        second = canteen;
      }
      if (second == nothing)
        "You need a container to put it in, something like a canteen so that it doesn't splash all over the place.";
      if (second ~= canteen)
        "You can't put the water in ", (ThatOrThose)second, ".";
      if (canteen hasnt open)
      {
        print (string)FIRST_OPENING_CANTEEN;
        give canteen open;
      }
      if (water in canteen)
        "The canteen is already full.";
      move water to canteen;
      print_ret (string)YOU_FILL_CANTEEN;
    ],
  found_in room07 room36,
has scenery;

!----------------------------------------
! Tufts of grass
!----------------------------------------
Object "grass" room07
with
  name 'tufts' 'of' 'grass',
  description "The tufts of grass are able to survive in this arid desert because of the water in the basin.",
has scenery;

