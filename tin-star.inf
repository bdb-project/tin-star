!========================================
! Room 18: Sierra Sedona
!========================================
Object room18 "Sierra Sedona"
with
  name 'sierra' 'sedona',
  description [;
    if (self hasnt visited)
      print "From now on you should be mounting your horse whenever possible. There is a long distance to cover.^^";
      "Around you, for miles, is the vast Sierra Sedona. To the east, you see the deadly vastness of the desert, while to the south, the Sierra continues until it merges, in the distance, with the horizon.";
    ],
  n_to room17,
  s_to room24,
  cheap_scenery
    2 'desert' 'expanse' "Huge, hopeless, deadly..."
    1 'sand' "The glaring sun turns it into a sea of gold, but there's no richness here - only death."
    1 'sun' "Hot. Relentless.",
has horsey light;

!========================================
! Room 19: Great Plains
!========================================
Object room19 "Great Plains"
with
  name 'great' 'plains',
  description "You have arrived in the Great Plains, where herds of bison usually find food and shelter. At present, though, you cannot spot any bison, here. To the west, in the distance, you see the Sierra Sedona, and beyond the plains, much further south, a mountain range.",
  s_to room25,
  w_to room24,
has horsey light;

!========================================
! Room 20: End of Plateau
!========================================
Object room20 "End of Plateau"
with
  name 'end' 'of' 'vast' 'plateau',
  description [;
    print "The vast plateau ends here in front of the entrance to an old gold mine. "; 
    if (self hasnt general)
      print "At present you cannot enter it since a landslide has covered the only access, leaving only a small hole. ";
    else
      print "The way is now open, thanks to the powerful explosion.";
    "To the south the plateau extends for a very long stretch.";
  ],
  s_to room26,
  in_to, n_to "There are rocks blocking the entrance and you can't get in.",
has light;

!----------------------------------------
