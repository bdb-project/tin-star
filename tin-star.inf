!----------------------------------------
Object trough "watering trough" room36
with
  name 'rain' 'watering' 'trough',
  description "It's a long, shallow container from which horses drink. It's full of rain water.",
  before
  [;
    DrinkFrom:
      <<Drink bulk_water self>>;
  ],
