! Log (floating object)
!----------------------------------------
Object log "log across the gorge"
with
  name 'long' 'log',
  description "It's the tree that you chopped down. It makes a good, albeit leafy, makeshift bridge across the gorge.",
  before
  [;
    Enter:
      if (self in room32)
        <<Go FAKE_S_OBJ>>;
      else
        <<Go FAKE_N_OBJ>>;
    Take:
      "It's wedged between the rocks.";
  ],
  found_in room32 room33,
has absent static;

