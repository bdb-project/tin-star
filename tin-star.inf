!----------------------------------------
! Navajo hatchet
!----------------------------------------
Object hatchet "Navajo hatchet" room30
with
  name 'navajo' 'hatchet' 'axe',
  description "It's a single-handed axe with a straight shaft and a head made of iron.",
  after
  [;
    Take:
      if (self hasnt moved && torch in player)
      {
        move torch to limbo;
        move branch to player;
        "As you pick up the hatchet, the dripping water douses your torch. Now you're in trouble.";
      }
  ],
has;

!========================================
! Room 31: Mining Tunnel
!========================================
Object room31 "Mining Tunnel"
with
  description
  [;
    print (string)MINE_DESCRIPTION;
    if (boards notin self)
      print " Sunlight shines in from the entrance to the south.";
    "";
  ],
  n_to room29,
  s_to room32,!Conditional, see before routine
  e_to room31,
  w_to room31,
  out_to room32,!Conditional, see before routine
  before
  [;
    Go:
      if (selected_direction == s_to or out_to && boards in self)
      {
        PrintMsg(MSG_GO_CANT_GO);
        rtrue;
      }
    Hint:
      if (location == thedark)
      {
        if (boards in self)
        {
          print "Have you examined the cracks of light? You should be able to chop your way through those boards";
          if (hatchet hasnt moved)
            ", but you'll need something sharp.";
          else
            ". You've found what you need.";
        }
        print_ret (string)YOU_NEED_LIGHT_SOURCE;
      }
      print_ret (string)LISTEN_OR_DROP_ITEM;
    Listen:
      if (noun == nothing)
        print_ret (string)CONSTANT_DRIPPING_COMES_FROM, "the northwest.";
  ],
has;

!----------------------------------------
! Boards
!----------------------------------------
Object boards "boards" room31
with
  name 'cracks' 'of' 'light' 'rough-sawn' 'rough' 'sawn' 'wooden' 'boards' 'boarded-up' 'boarded' 'up' 'entrance',
  description "It looks like another entrance has been boarded up from the outside. Cracks of light shine through the boards.",
  before
  [;
    Cut:
      if (second == nothing && hatchet in player)
      {
        print "(with the hatchet)^";
        second = hatchet;
      }
      if (second == nothing)
        "You have nothing to break it with.";
      if (second ~= hatchet)
        "You can't very well break through the boarded-up entrance with ", (a)second, ".";
      remove self;
      give real_location light;
      "You chop away at the boards with the hatchet until you've created a new entrance to the south.^";
    Attack, Push:
      if (second == hatchet)
        <<Cut self second>>;
      "The boards are very sturdy. You'll need to chop your way through them.";
    Touch:
      "You can feel rough-sawn wooden boards. They feel very sturdy.";
  ],
has pluralname scenery;

!========================================
! Room 32: North Side of Gorge
!========================================
Object room32 "North Side of Gorge"
with
  description "You're in the open air outside the mine, where you find yourself on the edge of a deep gorge. The mine is to the north and the gorge is to the south, but the bridge across the gorge has been destroyed. There's only a cluster of trees between you and the gorge.",
  n_to room31,
  s_to
  [;
    if (log notin self)
      "You can't go south, since the bridge has been destroyed.";
    return room33;
  ],
  in_to room31,
  before
  [;
    Hint:
      if (log notin self)
        "The tomahawk chopped through the boards, so maybe it can chop through other forms of wood.";
      if (room33 hasnt visited)
        "What are you waiting for? Cross the log.";
  ],
has light;

!----------------------------------------
! Gorge (floating object)
!----------------------------------------
Object "gorge" room32
with
  name 'edge' 'of' 'deep' 'gorge' 'steep' 'side' 'sides',
  description "The gorge is deep, with steep sides, so don't try climbing down or you'll surely fall to your death.",
  found_in room32 room33,
has scenery;

!----------------------------------------
! Destroyed bridge (floating object)
!----------------------------------------
Object "destroyed bridge"
with
  name 'destroyed' 'bridge',
  description
  [;
    print "The bridge was probably cut down by the bandits so that lawmen, like you, can't follow them. It now hangs down ";
    if (self in room32)
      print "this";
    else
      print "the other";
    print " side of the gorge, so it's impossible to use as a bridge. ";
    if (log notin location)
      print "You'll have to find another way";
    else
      print "However, you can now use the log";
    " to cross the gorge.";
  ],
  before
  [;
    Climb, Enter:
      "You carefully climb down the side of the gorge using the destroyed bridge as a sort of ladder. However, the bridge stops a long way short of the bottom of the gorge, so you climb back up again.";
  ],
  found_in room32 room33,
has static;

!----------------------------------------
! Cluster of trees
!----------------------------------------
Object "cluster of trees" room32
with
  name 'cluster' 'of' 'tree' 'trees',
  description "Some very high trees grow close to the edge of the gorge. Maybe cutting one down could help you to cross it.",
  before
  [;
    Climb:
      "This is not the time to be looking for birds' nests.";
    Cut:
      if (log notin nothing)
        "You've already cut down a tree. There's no need to denude the whole forest.";
      if (second == nothing && hatchet in player)
      {
        print "(with the hatchet)^";
        second = hatchet;
      }
      if (second == nothing)
        "You'd need an axe if you expect to chop down a tree.";
      if (second ~= hatchet)
        "You can't very well chop down a tree with ", (a)second, ".";
      give log ~absent;
      MoveFloatingObjects();
      "A hatchet is not really made for chopping down trees, but after considerable time and persistence, you finally manage to chop down one of the taller trees. It falls towards the other side of the gorge with a thundering crash to create an excellent makeshift bridge.";
  ],
has scenery;

